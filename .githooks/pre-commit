#!/bin/sh
# FindA.Sale pre-commit hook
# Checks: no .env files staged, no console.log in staged backend files (except guarded)
# Install: git config core.hooksPath .githooks (already set for pre-push)

set -e

# ── 1. Block .env files from being committed ────────────────────────────────
STAGED_ENV=$(git diff --cached --name-only | grep -E '\.env$|\.env\.' | grep -v '\.env\.example' | grep -v '\.env\.local\.example' || true)
if [ -n "$STAGED_ENV" ]; then
  echo "❌ Pre-commit blocked: .env file(s) staged for commit:"
  echo "$STAGED_ENV"
  echo "   Remove them with: git restore --staged <file>"
  exit 1
fi

# ── 2. Block obvious secret patterns in staged files ───────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)
if [ -n "$STAGED_FILES" ]; then
  for file in $STAGED_FILES; do
    if git show ":$file" 2>/dev/null | grep -qE '(sk_live_|pk_live_|rk_live_)[a-zA-Z0-9]{10,}'; then
      echo "❌ Pre-commit blocked: possible Stripe live key in $file"
      exit 1
    fi
  done
fi

# ── 3. Warn (don't block) on unguarded console.log in backend routes/controllers ──
BACKEND_STAGED=$(echo "$STAGED_FILES" | grep -E 'packages/backend/src/(routes|controllers)/' || true)
if [ -n "$BACKEND_STAGED" ]; then
  for file in $BACKEND_STAGED; do
    if git show ":$file" 2>/dev/null | grep -n 'console\.log' | grep -qv 'NODE_ENV\|DEV\|debug\|✅\|❌\|⚠️'; then
      echo "⚠️  Warning: unguarded console.log found in $file"
      echo "   Consider wrapping with: if (process.env.NODE_ENV !== 'production')"
    fi
  done
fi

echo "✅ Pre-commit checks passed."
exit 0
