#!/bin/sh
# FindA.Sale pre-push hook — Sprint T2
# Checks: TypeScript, Prisma schema lint, controller stubs, auth coverage
# Install: git config core.hooksPath .githooks

echo "[pre-push] Starting pre-push checks..."

# ── 1. TypeScript check (frontend) ──────────────────────────────────────────
echo "[pre-push] 1/4 TypeScript check..."
cd packages/frontend && npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ [pre-push] TypeScript errors. Push aborted."
  exit 1
fi
cd ../..
echo "  ✅ TypeScript passed."

# ── 2. Prisma schema validation ───────────────────────────────────────────────
echo "[pre-push] 2/4 Prisma schema lint..."
cd packages/database && npx prisma validate --schema prisma/schema.prisma 2>&1
if [ $? -ne 0 ]; then
  cd ../..
  echo "❌ [pre-push] Prisma schema invalid. Push aborted."
  exit 1
fi
cd ../..
echo "  ✅ Prisma schema valid."

# ── 3. Controller stubs: console.log / TODO / alert( ─────────────────────────
echo "[pre-push] 3/4 Controller stub check..."
CTRL_DIR="packages/backend/src/controllers"

CONSOLE_HITS=$(grep -rn 'console\.log' "$CTRL_DIR" --include="*.ts" \
  | grep -v 'NODE_ENV\|process\.env\|✅\|❌\|⚠️\|catch\|error\|Error' \
  | head -10 || true)
if [ -n "$CONSOLE_HITS" ]; then
  echo "⚠️  Unguarded console.log in controllers (clean up before launch):"
  echo "$CONSOLE_HITS"
fi

TODO_HITS=$(grep -rn 'TODO\|FIXME' "$CTRL_DIR" --include="*.ts" | head -5 || true)
if [ -n "$TODO_HITS" ]; then
  echo "⚠️  TODO/FIXME markers in controllers:"
  echo "$TODO_HITS"
fi

ALERT_HITS=$(grep -rn 'alert(' "$CTRL_DIR" --include="*.ts" | head -5 || true)
if [ -n "$ALERT_HITS" ]; then
  echo "❌ alert() in controller code. Push aborted."
  echo "$ALERT_HITS"
  exit 1
fi
echo "  ✅ Controller stub check passed."

# ── 4. Auth coverage on mutation routes ──────────────────────────────────────
# Uses file-level grep instead of per-line subshells — avoids hang on large route dirs
echo "[pre-push] 4/4 Auth coverage check..."
ROUTE_DIR="packages/backend/src/routes"

for routefile in "$ROUTE_DIR"/*.ts; do
  filename=$(basename "$routefile")
  case "$filename" in
    # Known fully-public routes (no auth by design)
    auth.ts|contact.ts|geocode.ts|stripe.ts) continue ;;
    # Routes where all mutations are intentionally public (documented in each file)
    abTest.ts|feedback.ts|invites.ts|planner.ts) continue ;;
  esac
  # Skip files that apply authenticate to all routes via router.use() — with or without extra middleware
  if grep -qE 'router\.use\(authenticate[,)]' "$routefile"; then
    continue
  fi
  # Find mutation lines that don't contain authenticate on the same line
  # Skip lines with inline "public" or "no auth" comments
  hits=$(grep -nE 'router\.(post|put|patch|delete)\s*\(' "$routefile" \
         | grep -v 'authenticate' \
         | grep -v '# public\|\/\/ public\|no auth' || true)
  if [ -n "$hits" ]; then
    echo "  ⚠️  $filename (verify auth manually):"
    echo "$hits" | while IFS= read -r h; do echo "    $h"; done
  fi
done

echo "  ✅ Auth coverage check complete."

echo ""
echo "✅ [pre-push] All checks passed."
exit 0
