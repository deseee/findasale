# Local dev: http://localhost:5000/api | Production: https://api.finda.sale/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_key_here

# PWA Push Notifications — must match VAPID_PUBLIC_KEY in backend .env
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Sentry error monitoring — get DSN from sentry.io → project settings
NEXT_PUBLIC_SENTRY_DSN=

# ── Region Configuration ──────────────────────────────────────────────────
# Frontend-accessible region settings. Defaults to Grand Rapids, MI.
NEXT_PUBLIC_DEFAULT_CITY=Grand Rapids
NEXT_PUBLIC_DEFAULT_STATE=MI
NEXT_PUBLIC_MAP_CENTER_LAT=42.9634
NEXT_PUBLIC_MAP_CENTER_LNG=-85.6681
