generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — used by app at runtime
  directUrl = env("DIRECT_URL") // direct connection — required for migrations (Prisma)
}

model User {
  id                           String                 @id @default(cuid())
  email                        String                 @unique
  password                     String? // Optional: OAuth users won't have a password
  name                         String
  role                         String                 @default("USER") // USER, ORGANIZER, ADMIN (deprecated — use roles array in Phase 3)
  roles                        String[]               @default(["USER"]) // ["USER"], ["USER", "ORGANIZER"], ["USER", "ORGANIZER", "ADMIN"]
  phone                        String?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  referralCode                 String?                @unique
  resetToken                   String?                @unique
  resetTokenExpiry             DateTime?
  // SECURITY FIX P1: Token version for invalidating old JWTs on password change
  tokenVersion                 Int                    @default(0) // Increment on password change to invalidate old tokens
  // Phase 31: OAuth / NextAuth social login
  oauthProvider                String? // "google", "facebook", null for email/password auth
  oauthId                      String? // Provider's unique user ID
  // Buyer-to-Sale Matching: user's interest categories
  categoryInterests            String[]               @default([])
  // Organizer referral credits: accumulated platform fee discounts
  organizerCredits             Float                  @default(0)
  organizer                    Organizer?
  roleSubscriptions            UserRoleSubscription[] @relation("roleSubscriptions") // Feature #72: Dual-role account subscriptions
  purchases                    Purchase[]
  favorites                    Favorite[]
  bids                         Bid[]
  maxBids                      MaxBidByUser[] // ADR-013 Phase 2: Proxy bidding
  subscriptions                SaleSubscriber[]
  userBadges                   UserBadge[]
  referredUsers                Referral[]             @relation("ReferrerToReferred")
  referredBy                   Referral?              @relation("ReferredToReferrer")
  lineEntries                  LineEntry[]
  reviews                      Review[]
  affiliateLinks               AffiliateLink[]
  pushSubscriptions            PushSubscription[]
  following                    Follow[]
  pointsTransactions           PointsTransaction[]
  shopperConversations         Conversation[]         @relation("ShopperConversations")
  sentMessages                 Message[]              @relation("SentMessages")
  reservations                 ItemReservation[]
  bounties                     MissingListingBounty[]
  organizerSubmissions         BountySubmission[]     @relation("OrganizerSubmissions")
  earlyAccessCaches            EarlyAccessCache[]
  webhooks                     Webhook[]
  treasureHuntFinds            TreasureHuntFind[]
  streakPoints                 Int                    @default(0)
  unsubscribeTokens            UnsubscribeToken[]
  visitStreak                  Int                    @default(0)
  lastVisitDate                DateTime?
  huntPassActive               Boolean                @default(false)
  huntPassExpiry               DateTime?
  huntPassCancelledAt          DateTime? // P0 Exploit Fix: timestamp when HP was cancelled, for XP redemption hold
  huntPassStripeCustomerId     String? // Stripe Customer for HP billing (shopper-side, separate from organizer)
  huntPassStripeSubscriptionId String? // Active HP Stripe Subscription ID; null = not subscribed
  userStreaks                  UserStreak[]
  wishlists                    Wishlist[]
  createdPools                 BuyingPool[]           @relation("CreatedPools")
  poolParticipations           PoolParticipant[]      @relation("PoolParticipations")
  notifications                Notification[]
  checkoutAttempts             CheckoutAttempt[]
  waitlistEntries              ItemWaitlist[]
  pickupBookings               PickupBooking[]
  saleCheckins                 SaleCheckin[] // Feature #121: GPS-based check-ins for hold validation
  notificationPrefs            Json? // Notification preferences: { emailNewSalesFromFollowed, emailFlashDeals, emailWeeklyDigest, pushSalesNearMe }
  emailWeeklyOrganizerDigest   Boolean                @default(true) // Organizer weekly analytics digest preference
  feedbacks                    Feedback[]
  betaInviteUsed               BetaInvite? // One-to-one: user can only use one invite
  reviewVotes                  ReviewVote[]
  savedSearches                SavedSearch[]
  saleRSVPs                    SaleRSVP[]
  organizerReferrer            OrganizerReferral[]    @relation("ReferrerOrganizer")
  organizerReferee             OrganizerReferral?     @relation("RefereeOrganizer")
  disputesAsBuyer              Dispute[]              @relation("DisputeBuyer")
  disputesAsSeller             Dispute[]              @relation("DisputeSeller")
  messageTemplates             MessageTemplate[]      @relation("OrganizerTemplates")
  saleWaitlist                 SaleWaitlist[]
  saleReminders                SaleReminder[]
  coupons                      Coupon[]
  // Task #7: Shopper Referral Rewards
  referralRewardsGiven         ReferralReward[]       @relation("ReferralRewardsGiven")
  referralRewardsReceived      ReferralReward[]       @relation("ReferralRewardsReceived")
  // Feature #32: Wishlist Alerts + Smart Follow
  wishlistAlerts               WishlistAlert[]
  smartFollows                 SmartFollow[]
  // Feature #29: Loyalty Passport
  stamps                       ShopperStamp[]
  stampMilestones              StampMilestone[]
  // Feature #55: Seasonal Discovery Challenges
  challengeProgress            ChallengeProgress[]
  challengeBadges              ChallengeBadge[]
  // Feature #45: Collector Passport — identity-based collection tracking
  collectorPassport            CollectorPassport?
  // Feature #47: UGC Photo Tags — user-generated content with tagging and likes
  ugcPhotos                    UGCPhoto[]
  ugcPhotoLikes                UGCPhotoLike[]
  ugcPhotoReactions            UGCPhotoReaction[]     @relation("UGCPhotoReactions") // Feature #88: Haul Posts
  // Features #58-59: Achievement Badges & Streak Rewards
  achievements                 UserAchievement[]      @relation("UserAchievements")
  streak                       VisitStreak?           @relation("UserStreak")
  // Feature #19: Passkey/WebAuthn Support
  passkeys                     PasskeyCredential[]    @relation("UserPasskeys")
  // Feature #17: Bid Bot Detector — fraud signals and reviews given
  fraudSignals                 FraudSignal[]          @relation("UserFraudSignals")
  fraudReviewsGiven            FraudSignal[]          @relation("FraudReviewsBy")
  // Feature #48: Treasure Trail Route Builder — user-created trails
  trails                       TreasureTrail[]        @relation("UserTrails")
  // Feature #48: Treasure Trails — check-ins, photos, completions, ratings
  trailCheckIns                TrailCheckIn[]
  trailPhotos                  TrailPhoto[]
  trailCompletions             TrailCompletion[]
  trailRatings                 TrailRating[]
  // Feature #85: Treasure Hunt QR — per-sale scavenger hunt scans
  treasureHuntQRScans          TreasureHuntQRScan[]   @relation("TreasureHuntQRScans")
  // Feature #87: Brand & Designer Tracking
  brandFollows                 BrandFollow[]
  // Feature #52: Estate Sale Encyclopedia
  encyclopediaEntries          EncyclopediaEntry[]    @relation("EncyclopediaAuthor")
  encyclopediaRevisions        EncyclopediaRevision[] @relation("EncyclopediaRevisionAuthor")
  encyclopediaVotes            EncyclopediaVote[]     @relation("EncyclopediaVote")
  // Feature #71: Organizer Reputation Score
  reputation                   OrganizerReputation?
  // Feature #54: Crowdsourced Appraisal API
  appraisalRequests            AppraisalRequest[]     @relation("AppraisalRequests")
  appraisalResponses           AppraisalResponse[]    @relation("AppraisalResponses")
  appraisalAIRequests          AppraisalAIRequest[]   @relation("AppraisalAIRequests")
  appraisalDisputes            AppraisalDispute[]     @relation("AppraisalDisputes")
  // Feature #70: Consignment — pre-wire inverse relation for consigned items
  consignedItems               Item[]                 @relation("ConsignedItems")
  // Platform Safety #94: Same-IP Bidder Detection
  bidIpRecords                 BidIpRecord[]          @relation("BidIpRecords")
  // Feature #51: Sale Ripples — social proof activity
  ripples                      SaleRipple[]           @relation("SaleRipples")
  // Feature #60: TEAMS Onboarding Wizard completion flag
  teamsOnboardingComplete      Boolean                @default(false)
  // Feature #72: Affiliate Program — referral code and payouts
  affiliateReferralCode        String?                @unique // Unique code for affiliate referral tracking
  affiliatePayoutsGiven        AffiliatePayout[]      @relation("AffiliatePayoutsGiven")
  affiliatePayoutsReceived     AffiliatePayout[]      @relation("AffiliatePayoutsReceived")
  affiliateReferralsGiven      AffiliateReferral[]    @relation("AffiliateReferrals_Referrer")
  affiliateReferralsReceived   AffiliateReferral[]    @relation("AffiliateReferrals_Referred")
  // Hold-to-Pay feature: invoices (shopper and organizer sides)
  shopperInvoices              HoldInvoice[]          @relation("ShopperInvoices")
  organizerInvoices            HoldInvoice[]          @relation("OrganizerInvoices")
  // Feature #228: Settlement Hub — buyer transaction history
  saleTransactions             SaleTransaction[]
  // POS Upgrade: Shopper cart sessions
  shopperPOSSessions           POSSession[]           @relation("ShopperPOSSessions")
  // POS In-App Payment Requests
  posPaymentRequestsAsSender   POSPaymentRequest[]    @relation("OrganizerPaymentRequests")
  posPaymentRequestsAsReceiver POSPaymentRequest[]    @relation("ShopperPaymentRequests")

  // Phase 2a: Explorer's Guild — XP Economy
  guildXp           Int           @default(0) // Phase 2a: Cumulative XP, never resets, used for rank calculation
  explorerRank      ExplorerRank  @default(INITIATE) // Phase 2a: Current explorer rank (derived from guildXp, denormalized for fast lookup)
  seasonalResetAt   DateTime? // Phase 2a: Most recent Jan 1 UTC seasonal reset timestamp
  rankUpHistory     Json          @default("[]") // Phase 2a: Array of { rank, timestamp, xpAtTime } for Hall of Fame + seasonal tracking
  // D-XP-002: XP Expiry System
  lifetimeXpEarned  Int           @default(0) // Total XP ever earned (never decremented) — used for Grandmaster+ (5000+) expiry exemption
  lastXpActivityAt  DateTime? // Last time XP-earning activity occurred (purchase, haul post, referral) — basis for expiry calculation
  xpExpiresAt       DateTime? // When remaining XP balance expires (computed: lastXpActivityAt + 365 days)
  xpExpiryWarned300 Boolean       @default(false) // Flag: 300-day warning (65 days remaining) notification sent
  xpExpiryWarned350 Boolean       @default(false) // Flag: 350-day warning (15 days remaining) notification sent
  rarityBoosts      RarityBoost[] @relation("RarityBoosts") // Phase 2a: Active rarity boosts for upcoming sales
  passportCompleted Boolean       @default(false) // Phase 2a: Collector Passport completed (earned COLLECTOR_PASSPORT_COMPLETE 50 XP)
  foundedCrews      Crew[]        @relation("CrewFounder")
  crewMemberships   CrewMember[]  @relation("CrewMemberships")

  // Platform Safety #99: Export Rate Limiting (1 per month per account)
  lastExportAt DateTime?

  // Feature #84: Approach Notes — push notification tracking
  pushNotificationLogs PushNotificationLog[]

  // Platform Safety #102: Payment Method Deduplication
  stripeCardFingerprint String?

  // Platform Safety #118: Device Fingerprinting for Multi-Account Fraud Detection
  deviceFingerprint String? // Hashed device fingerprint (user agent + screen + timezone + canvas)
  fraudSuspect      Boolean @default(false) // Flag: set true if 2+ accounts share same device fingerprint

  // Feature #XXX: First Sale Free PRO — Email Verification Gate
  emailVerified           Boolean   @default(false) // Whether user has verified their email address
  emailVerificationToken  String?   @unique // Random token for email verification link
  emailVerifiedAt         DateTime? // Timestamp when email was verified

  // Platform Safety #107-#114: Organizer Reputation & Suspension Tracking
  chargebackCount      Int               @default(0) // Total chargebacks on user's organizer account
  bidCancellationCount Int               @default(0) // Total bids cancelled by user (as buyer)
  suspendedAt          DateTime? // Account suspension timestamp (null = active)
  suspendReason        String? // Reason for suspension: SERIAL_CHARGEBACKS, BID_CANCEL_PATTERN, COLLUSION_SUSPECT
  // Feature #106: Crowdsourced Sourcebook — expert notes and appraisals on items/sales
  sourcebookEntries    SourcebookEntry[] @relation("SourcebookAuthor")
  organizedSourcebook  SourcebookEntry[] @relation("OrganizerSourcebook")

  // Task #200: Shopper Public Profiles
  profileSlug      String? @unique // Optional custom slug for public profile URL
  purchasesVisible Boolean @default(true) // Toggle to show/hide purchase history on public profile
  collectorTitle   String? // Title from curated list (e.g., "Furniture Curator", "Vintage Hunter")

  // Feature: Feedback System — Survey suppression tracking
  feedbackSuppressions FeedbackSuppression[]
  firstSalePublished   Boolean               @default(false) // For OG-1 trigger gate
  lastSurveyShownAt    DateTime? // For session/cooldown logic

  // Phase 2b: Boost Purchase — XP or Stripe promotional boosts
  boostPurchases BoostPurchase[]

  // Phase 2b: Lucky Roll — weekly XP gacha
  luckyRollPityCount    Int         @default(0) // Consecutive consolation-outcome roll count (0, 1, 2; layer-1 pity fires at 2)
  luckyRollPityYear     Int         @default(0) // Cumulative roll count this calendar year (layer-2 jackpot guarantee fires every 10)
  luckyRollLastRolledAt DateTime? // Most recent roll timestamp — enforces weekly cap
  luckyRollStreakBad    Int         @default(0) // Hidden: consecutive below-break-even count (consolation or 50 XP); streak protection doubles jackpot% at 5
  luckyRolls            LuckyRoll[]

  // Phase 2c: XP Sinks — Custom Map Pin (cosmetic)
  customMapPin String? // Emoji or short string (max 4 chars) for map pin override

  // Phase 2c: XP Sinks — Profile Showcase Slots
  showcaseSlots Int            @default(1) // How many showcase slots unlocked (1 free, +1 at 50 XP, +1 more at 150 XP)
  showcases     UserShowcase[]

  workspaceMemberships WorkspaceMember[] @relation("UserWorkspaceMemberships")

  @@unique([oauthProvider, oauthId]) // Prevent duplicate OAuth accounts
  @@index([guildXp])
  @@index([explorerRank])
  @@index([suspendedAt])
  @@index([xpExpiresAt]) // D-XP-002: For nightly expiry cron query
  @@index([lastXpActivityAt]) // D-XP-002: For tracking last activity
  @@index([deviceFingerprint]) // Platform Safety #118: Fast fraud detection lookups
  @@index([fraudSuspect]) // Platform Safety #118: Fast fraud account filtering
}

model Organizer {
  id                      String                 @id @default(cuid())
  businessName            String
  phone                   String
  address                 String
  bio                     String? // Organizer bio/description (optional)
  website                 String? // Business website URL
  profilePhoto            String? // Profile photo URL (Cloudinary)
  facebook                String? // Facebook page URL
  instagram               String? // Instagram profile URL
  etsy                    String? // Etsy shop URL
  serviceAreas            String? // CSV or JSON of cities/zip codes served
  pickupWindows           String? // Default pickup availability (JSON or text)
  userId                  String                 @unique
  user                    User                   @relation(fields: [userId], references: [id])
  sales                   Sale[]
  saleTemplates           SaleTemplate[]
  stripeConnectId         String?
  // Phase 17: Reputation
  reputationTier          String                 @default("NEW") // NEW, TRUSTED, ESTATE_CURATOR
  avgRating               Float?
  totalReviews            Int                    @default(0)
  totalSales              Int                    @default(0)
  followers               Follow[]
  conversations           Conversation[]
  // Feature #32: Smart Follow — shoppers following this organizer for sale alerts
  smartFollowers          SmartFollow[]
  // Phase 31: Organizer Tier Rewards (BRONZE | SILVER | GOLD) — fee benefits based on activity
  tier                    String                 @default("BRONZE")
  tierUpdatedAt           DateTime?
  // Feature #16: Verified Organizer Badge
  verificationStatus      String                 @default("NONE") // NONE | PENDING | VERIFIED | REJECTED
  verificationNotes       String?
  verifiedAt              DateTime?
  // Feature #83: Estate Planning — executor account stub
  executorUserId          String?
  estateId                String? // Pre-wire: Estate Planning Toolkit — references future Estate model
  // Onboarding wizard
  onboardingComplete      Boolean                @default(false)
  // Feature #11: Referral discount — fee waived for 3 months when referred by/referring another organizer
  referralDiscountExpiry  DateTime?
  // Cash POS: accumulated platform fees awaiting payout deduction
  cashFeeBalance          Float                  @default(0)
  cashFeeBalanceUpdatedAt DateTime?
  // #31 Brand Kit: organizer branding for sales and exports
  brandLogoUrl            String? // Cloudinary URL for organizer logo
  brandPrimaryColor       String? // Hex e.g. "#2563EB"
  brandSecondaryColor     String? // Hex e.g. "#1E40AF"
  customStorefrontSlug    String?                @unique // Unique slug for organizer storefront e.g. "janes-estate-sales"
  brandFontFamily         String? // Font family e.g. "Georgia" (PRO tier)
  brandBannerImageUrl     String? // Cloudinary URL for organizer banner (PRO tier)
  brandAccentColor        String? // Hex for accent color (PRO tier)
  // Feature #65: Subscription Tiers
  subscriptionTier        SubscriptionTier       @default(SIMPLE)
  subscriptionStatus      String? // active, trialing, past_due, canceled, null
  trialEndsAt             DateTime?
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  // SECURITY FIX P0-1: Token version for invalidating tier JWTs on subscription upgrade
  tokenVersion            Int                    @default(0) // Increment on tier upgrade to invalidate stale tier claims in JWT
  // Feature #40: Sale Hubs — hubs created by this organizer
  hubs                    SaleHub[]              @relation("OrganizerHubs")
  // Feature #13: TEAMS Multi-User Workspace relations
  workspace               OrganizerWorkspace?    @relation("WorkspaceOwner")
  workspaceMemberships    WorkspaceMember[]      @relation("OrganizerWorkspaces")
  // D-007: Enterprise account flag (unlimited team members, annual contracts)
  isEnterpriseAccount     Boolean                @default(false)
  // Feature #121: Hold system settings
  holdSettings            OrganizerHoldSettings?
  // Feature #228: Settlement Hub — default commission rate for estate/consignment/auction
  defaultCommissionRate   Decimal?
  // Feature #235: Charity Close + Tax Receipt PDF
  donations               SaleDonation[]
  // POS Upgrade: Open Cart sessions and payment links
  posSessions             POSSession[]
  posPaymentLinks         POSPaymentLink[]
  // Feature #48: Treasure Trails — organizer-created discovery trails
  trails                  TreasureTrail[]        @relation("OrganizerTrails")
  // Feature #244 Phase 2: eBay OAuth connection
  ebayConnection          EbayConnection?        @relation("OrganizerEbayConnection")
  // Feature #244 Phase 2c: eBay Policy Routing — per-organizer weight-tier policy mappings
  ebayPolicyMapping       EbayPolicyMapping?     @relation("OrganizerEbayPolicyMapping")
  ebaySubscriptionId      String? // ORDER_CONFIRMATION subscription ID from eBay Notification API
  workspaceChatMessages   WorkspaceChatMessage[] @relation("WorkspaceChatMessages")
  // Feature #S483: Organizer Signals — expansion + churn scoring
  organizerScore          OrganizerScore?
  // Feature #XXX: First Sale Free PRO — Security Gates
  firstSaleFreeProUsedAt  DateTime? // When organizer used their first-sale free PRO offer (null = not used yet)
  aiTagsUsedThisMonth     Int       @default(0) // Count of AI tags used this calendar month
  aiTagsResetAt           DateTime? // When the monthly AI tag counter was last reset
  // Feature #75: eBay Push Quota Tracking — monthly limit enforcement
  ebayPushesThisMonth     Int       @default(0) // Count of eBay pushes this calendar month
  ebayPushesResetAt       DateTime? // When the monthly eBay push counter was last reset
  // Feature: Graceful Tier Degradation — grace period fields
  graceEndAt              DateTime? // When grace period expires (7 days from downgrade)
  graceTierBefore         String? // Tier before downgrade (PRO or TEAMS)
  graceNotificationsCount Int       @default(0) // Count of grace period notifications sent (0-2)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
}

// Feature #244 Phase 2: eBay OAuth Connection — stores refresh tokens and connection state
model EbayConnection {
  id String @id @default(cuid())

  // Foreign key to organizer
  organizerId String    @unique
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade, name: "OrganizerEbayConnection")

  // eBay OAuth tokens
  accessToken    String // 2-hour lifetime, refresh endpoint handles rotation
  refreshToken   String // 18-month lifetime, stored securely
  tokenExpiresAt DateTime // When accessToken expires

  // eBay seller identity
  ebayUserId       String // eBay seller username (returned in token response)
  ebayAccountEmail String? // Optional: eBay account email for reconciliation

  // Metadata
  connectedAt      DateTime  @default(now())
  lastRefreshedAt  DateTime  @default(now())
  lastErrorAt      DateTime?
  lastErrorMessage String?

  // Feature #244 Phase 2b: eBay business policy IDs (fetched from eBay Account API after OAuth)
  paymentPolicyId     String? // eBay payment policy ID (required for offer publishing)
  fulfillmentPolicyId String? // eBay fulfillment policy ID (required for offer publishing)
  returnPolicyId      String? // eBay return policy ID (required for offer publishing)
  policiesFetchedAt   DateTime? // When policies were last synced from eBay Account API

  // Feature #244 Phase 3: eBay sold sync deduplication
  lastEbaySoldSyncAt DateTime? // Last time this connection's sold orders were synced from eBay

  // eBay inventory import: when eBay inventory was last pulled into FindA.Sale
  lastEbayInventorySyncAt DateTime?

  // ADR eBay Parity Phase A: Real merchant location tracking
  merchantLocationKey    String?
  merchantLocationSource String? // EXISTING | SALE_ADDRESS | ORGANIZER_ADDRESS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId])
  @@index([lastRefreshedAt])
}

// Feature #244 Phase 2c: eBay Policy Routing — per-organizer mapping of item attributes → eBay policies
model EbayPolicyMapping {
  id          String    @id @default(cuid())
  organizerId String    @unique
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade, name: "OrganizerEbayPolicyMapping")

  // Fallback default policies (used when no mapping rule matches)
  defaultFulfillmentPolicyId String?
  defaultReturnPolicyId      String?
  defaultPaymentPolicyId     String?
  defaultDescriptionHtml     String? @db.Text // HTML template used when item has no custom description template

  // Weight-tier mappings — JSON array of { maxOz: number, policyId: string, policyName: string }
  // Sorted by maxOz ascending. At push time, find first tier where item.weightOz <= tier.maxOz.
  weightTierMappings Json @default("[]")

  // Category overrides — JSON array of { categoryId: string, policyId: string, policyName: string }
  // Checked BEFORE weight tiers. If item.ebayCategoryId matches, use this policy regardless of weight.
  categoryOverrides Json @default("[]")

  // Shipping classification overrides (item.shippingClassification-based routing)
  heavyOversizedPolicyId String? // e.g. "Local Pickup ONLY"
  fragilePolicyId        String?
  unknownPolicyId        String? // used when classification is UNKNOWN or missing

  // Push preferences
  pushAsDraft            Boolean @default(false) // if true, create Offer but don't call publish endpoint
  merchantLocationSource String  @default("SALE_ADDRESS") // EXISTING | SALE_ADDRESS | ORGANIZER_ADDRESS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId])
}

// Phase 2c: Profile Showcase Slots — user-pinned haul posts on profile
model UserShowcase {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  slotIndex  Int // 0, 1, or 2
  ugcPhotoId Int? // nullable — slot can be empty
  ugcPhoto   UGCPhoto? @relation(fields: [ugcPhotoId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userId, slotIndex])
  @@index([userId])
}

// Phase 2a Social Retention: Explorer's Guild — Crew Creation
model Crew {
  id            String                 @id @default(cuid())
  name          String                 @unique
  slug          String                 @unique
  description   String?                @db.VarChar(500)
  founderUserId String
  founder       User                   @relation("CrewFounder", fields: [founderUserId], references: [id], onDelete: Cascade)
  isPublic      Boolean                @default(true)
  memberCount   Int                    @default(1)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  members       CrewMember[]
  bounties      MissingListingBounty[]

  @@index([isPublic])
  @@index([createdAt])
}

model CrewMember {
  id       String   @id @default(cuid())
  crewId   String
  crew     Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation("CrewMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  @@unique([crewId, userId])
  @@index([crewId])
  @@index([userId])
}

// Feature #72: Dual-Role Account — Per-role subscription state, tier, and consent
model UserRoleSubscription {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, name: "roleSubscriptions")

  role String // "ORGANIZER" | "SHOPPER" (always paired with a User.roles entry)

  // Subscription state (ORGANIZER role only; SHOPPER is always active)
  subscriptionTier     SubscriptionTier @default(SIMPLE) // SIMPLE | PRO | TEAMS
  subscriptionStatus   String? // active, trialing, past_due, canceled, null
  trialEndsAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?

  // Tier expiry (Feature #75 gate)
  tierLapseWarning DateTime? // When to send tier-lapse warning email (e.g., 7 days before trialEndsAt)
  tierLapsedAt     DateTime? // When tier actually lapsed (SIMPLE fallback or canceled)
  tierResumedAt    DateTime? // When user reactivated subscription

  // Token version for tier JWT (SECURITY FIX P0-1)
  tokenVersion Int @default(0) // Increment on tier upgrade

  // ORGANIZER ONLY: Stripe Connect (for payouts)
  stripeConnectId String?

  // ORGANIZER ONLY: Reputation tier (Feature #71)
  reputationTier     String    @default("NEW") // NEW, TRUSTED, ESTATE_CURATOR
  verificationStatus String    @default("NONE") // NONE | PENDING | VERIFIED | REJECTED
  verifiedAt         DateTime?

  // Feature #74: Role-specific consent
  consentRecord RoleConsent?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, role]) // One subscription per role per user
  @@index([userId])
  @@index([role])
}

// Feature #72+74: Role-Specific Consent Records
model RoleConsent {
  id               String               @id @default(cuid())
  subscriptionId   String               @unique
  roleSubscription UserRoleSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  role String // "ORGANIZER" | "SHOPPER"

  // Consent timestamps: null = not yet consented
  termsAcceptedAt                DateTime?
  privacyAcceptedAt              DateTime?
  businessVerificationAcceptedAt DateTime? // ORGANIZER only
  paymentMethodAcceptedAt        DateTime? // ORGANIZER only
  marketingOptInAt               DateTime? // SHOPPER only

  // Marketing email opt-out per role
  emailOptOut Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
}

model Sale {
  id                          String                   @id @default(cuid())
  title                       String
  description                 String?
  startDate                   DateTime
  endDate                     DateTime
  address                     String
  city                        String
  state                       String
  zip                         String
  lat                         Float?
  lng                         Float?
  neighborhood                String? // Regional neighborhood slug e.g. "downtown"
  photoUrls                   String[]
  tags                        String[]
  status                      String                   @default("DRAFT") // DRAFT, PUBLISHED, ENDED
  isAuctionSale               Boolean                  @default(false) // Deprecated: use saleType instead
  saleType                    String                   @default("ESTATE") // B1: ESTATE | YARD | AUCTION | FLEA_MARKET
  qrScanCount                 Int                      @default(0)
  endingSoonNotified          Boolean                  @default(false) // Track if "Sale Ending Soon" notification has been sent
  // Feature #35: Front Door Locator — entrance/parking location
  entranceLat                 Float? // Latitude of entrance/parking location
  entranceLng                 Float? // Longitude of entrance/parking location
  entranceNote                String?                  @db.VarChar(150) // Optional note: "Side entrance", "Park in back", etc.
  notes                       String? // Feature #84: Day-of approach notes (parking, entrance, hours, etc.)
  // Feature #24: Holds-Only Item View — configurable hold duration per sale
  holdDurationHours           Int                      @default(48) // Default 48h hold; organizer can change per sale
  // #62: Digital Receipt + Returns — return window in hours
  returnWindowHours           Int?
  organizerId                 String
  organizer                   Organizer                @relation(fields: [organizerId], references: [id])
  items                       Item[]
  favorites                   Favorite[]
  subscribers                 SaleSubscriber[]
  affiliateLinks              AffiliateLink[]
  lineEntries                 LineEntry[]
  purchases                   Purchase[]
  reviews                     Review[]
  conversations               Conversation[]
  bounties                    MissingListingBounty[]
  flashDeals                  FlashDeal[]
  pickupSlots                 PickupSlot[]
  rsvps                       SaleRSVP[]
  checklist                   SaleChecklist?
  saleWaitlist                SaleWaitlist[]
  saleReminders               SaleReminder[]
  linkClicks                  LinkClick[] // #18: Post Performance Analytics
  // Feature #47: UGC Photo Tags — user-generated content linked to sales
  ugcPhotos                   UGCPhoto[]
  // Feature #39: Photo Op Stations — branded selfie spots, shareable UGC moments
  photoOpStations             PhotoOpStation[]         @relation("SalePhotoOps")
  // Feature #17: Bid Bot Detector — fraud signals for this sale
  fraudSignals                FraudSignal[]
  // Feature #40: Sale Hubs — membership in coordinated hubs
  hubMemberships              SaleHubMembership[]      @relation("SaleHubMemberships")
  // Feature #51: Sale Ripples — social proof activity feed
  ripples                     SaleRipple[]
  // Feature #85: Treasure Hunt QR — per-sale scavenger hunt with organizer-created clues
  treasureHuntQRClues         TreasureHuntQRClue[]
  treasureHuntEnabled         Boolean                  @default(true)
  treasureHuntCompletionBadge Boolean                  @default(false)
  // Feature #72: Affiliate Payouts linked to sales
  affiliatePayouts            AffiliatePayout[]
  // Phase 2a: Explorer's Guild — Rarity boosts for this sale
  rarityBoosts                RarityBoost[]            @relation("RarityBoosts")
  // #132: À La Carte Single-Sale Fee ($9.99)
  purchaseModel               String                   @default("SUBSCRIPTION") // "SUBSCRIPTION" | "ALA_CARTE"
  alaCarte                    Boolean                  @default(false)
  alaCarteFeePaid             Boolean                  @default(false)
  // #112 Soft-Delete Archival + #120 Sale Cancellation Audit
  deletedAt                   DateTime?
  cancellationReason          String?
  // Feature #91: Auto-Markdown (Smart Clearance)
  markdownEnabled             Boolean                  @default(false)
  markdownFloor               Float?
  // Feature #121: Hold system — check-ins and hold limits
  checkins                    SaleCheckin[]
  holdsEnabled                Boolean                  @default(true) // Feature #121: organizer can disable holds per-sale
  // Hold-to-Pay feature: invoices for held items
  holdInvoices                HoldInvoice[]
  // Feature #106: Prelaunch Preview — restrict inventory browse to Sage+ before this time
  prelaunchAt                 DateTime? // null = no prelaunch; before this time, only Sage+ can browse inventory
  // Sourcebook relations
  sourcebookEntries           SourcebookEntry[]        @relation("SaleSourcebookEntries")
  // Feature #228: Settlement Hub — lifecycle + commission + settlement
  lifecycleStage              String                   @default("LEAD") // LEAD|CONTRACTED|PREP|LIVE|POST_SALE|CLOSED
  commissionRate              Decimal? // organizer's % for estate/consignment/auction
  settlementNotes             String?
  settlement                  SaleSettlement?
  transactions                SaleTransaction[]
  // Feature #235: Charity Close + Tax Receipt PDF
  donations                   SaleDonation[]
  // Feature #371: Auto High-Value Item Flagging
  highValueThresholdUSD       Decimal                  @default(500)
  autoFlagHighValue           Boolean                  @default(true)
  // Feature #48: Treasure Trails — discovery trails anchored to this sale
  trails                      TreasureTrail[]          @relation("SaleTrails")
  trailStops                  TrailStop[]              @relation("SaleTrailStops")
  // POS Upgrade: Open Cart sessions and payment links
  posSessions                 POSSession[]
  posPaymentLinks             POSPaymentLink[]
  posPaymentRequests          POSPaymentRequest[]
  workspaceSalesActivity      WorkspaceSalesActivity[] @relation("WorkspaceSalesActivity")
  workspaceSaleChats          WorkspaceSaleChat[]      @relation("WorkspaceSaleChats")
  workspaceTasks              WorkspaceTask[]          @relation("WorkspaceTasks")
  workspaceAlerts             WorkspaceAlert[]         @relation("WorkspaceAlerts")
  // eBay inventory import: hidden DRAFT container sale for organizer's inventory items
  isInventoryContainer        Boolean                  @default(false)
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt

  @@index([deletedAt])
  @@index([prelaunchAt])
  @@index([lifecycleStage])
  @@index([organizerId, status, endDate]) // Feature #249: Concurrent Sales Gate optimization
}

// Feature #106: Crowdsourced Sourcebook — expert notes and appraisals on items/sales
model SourcebookEntry {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation("SourcebookAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  saleId      String?
  sale        Sale?    @relation("SaleSourcebookEntries", fields: [saleId], references: [id], onDelete: SetNull)
  organizerId String?
  organizer   User?    @relation("OrganizerSourcebook", fields: [organizerId], references: [id], onDelete: SetNull)
  title       String
  body        String
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([saleId, authorId])
  @@unique([organizerId, authorId])
  @@index([authorId, createdAt])
  @@index([saleId])
  @@index([organizerId])
}

model Item {
  id                         String                 @id @default(cuid())
  title                      String
  sku                        String?
  description                String?
  price                      Float?
  auctionStartPrice          Float?
  auctionReservePrice        Float?
  currentBid                 Float?
  bidIncrement               Float?                 @default(1)
  auctionEndTime             DateTime?
  auctionClosed              Boolean                @default(false)
  status                     String                 @default("AVAILABLE") // AVAILABLE, SOLD, RESERVED, INVOICE_ISSUED, AUCTION_ENDED, DONATED
  category                   String? // eBay L1 category name (e.g. "Home & Garden") — used for shopper browse and wishlist matching
  condition                  String? // NEW | USED | REFURBISHED | PARTS_OR_REPAIR
  conditionGrade             String? // S | A | B | C | D — null for items not yet graded
  rarity                     ItemRarity             @default(COMMON) // Feature #57: Shiny/Rare badges
  photoUrls                  String[]
  // U1: Ollama nomic-embed-text 768-dim vector for semantic search
  embedding                  Float[]
  // W1: Shipping
  shippingAvailable          Boolean                @default(false)
  shippingPrice              Float?
  // B1: Item listing/transaction type — FIXED | AUCTION | REVERSE_AUCTION | LIVE_DROP | POS
  listingType                String                 @default("FIXED")
  // CD2: Live Drop — item hidden until liveDropAt time
  isLiveDrop                 Boolean                @default(false) // Deprecated: use listingType instead
  liveDropAt                 DateTime?
  // B2: AI tagging disclosure — true when AI (Vision + Haiku) generated this item's fields
  isAiTagged                 Boolean                @default(false)
  // CB5: AI-generated search tags from batchAnalyzeController
  tags                       String[]               @default([])
  // CD2 Phase 4: Reverse Auction — daily price decline until sold or floor hit
  reverseAuction             Boolean                @default(false) // Deprecated: use listingType instead
  reverseDailyDrop           Int? // cents per day
  reverseFloorPrice          Int? // minimum price in cents
  reverseStartDate           DateTime?
  // Bulk operations: hide/show item from sale listing
  isActive                   Boolean                @default(true)
  saleId                     String
  sale                       Sale                   @relation(fields: [saleId], references: [id])
  bids                       Bid[]
  maxBids                    MaxBidByUser[] // ADR-013 Phase 2: Proxy bidding
  purchases                  Purchase[]
  favorites                  Favorite[]
  reservation                ItemReservation?
  bountyFulfillments         MissingListingBounty[]
  bountySubmissions          BountySubmission[]     @relation("BountySubmissions")
  treasureHuntFinds          TreasureHuntFind[]
  treasureHuntQRScans        TreasureHuntQRScan[]   @relation("TreasureHuntQRScans")
  flashDeals                 FlashDeal[]
  wishlistItems              WishlistItem[]
  buyingPools                BuyingPool[]
  checkoutAttempts           CheckoutAttempt[]
  waitlist                   ItemWaitlist[]
  currency                   String                 @default("USD") // Batch 17: multi-currency groundwork
  priceHistory               ItemPriceHistory[]
  draftStatus                String                 @default("DRAFT") // DRAFT | PENDING_REVIEW | PUBLISHED — Rapidfire Mode item draft status
  aiErrorLog                 Json? // Rapidfire Mode AI error logging (JSON array of errors)
  optimisticLockVersion      Int                    @default(0) // Rapidfire Mode optimistic concurrency control
  // Camera Workflow v2 fields
  aiConfidence               Float                  @default(0.5) // AI confidence score (0.0–1.0)
  backgroundRemoved          Boolean                @default(false) // Background removal applied
  faceDetected               Boolean                @default(false) // Face detected in image
  autoEnhanced               Boolean                @default(false) // Auto-enhancement applied
  photos                     Photo[] // Multi-photo support (forward-looking)
  // Feature #25: Item Library — organizer-owned items across sales
  libraryId                  String? // Links to future LibraryItem table; for now just namespace
  inInventory                Boolean                @default(false) // Cached: is this item in organizer's inventory?
  priceVariants              Json? // { saleId: price } for per-sale pricing (Phase 5)
  organizerId                String? // Denormalized from sale.organizerId for library queries
  // Feature #29: Loyalty Passport — Hunt Pass early access embargo
  earlyAccessUntil           DateTime? // Items hidden from non-Hunt-Pass shoppers until this time
  // Feature #47: UGC Photo Tags — user-generated content linked to items
  ugcPhotos                  UGCPhoto[]
  // Feature #17: Bid Bot Detector — fraud signals for this item
  fraudSignals               FraudSignal[]
  // Feature #48: Treasure Trail Route Builder — items highlighted on trails
  trailHighlights            TrailHighlight[]
  // Feature #30: AI Item Valuation — comparable sales valuation
  valuation                  ItemValuation?
  // Feature #235: Charity Close + Tax Receipt PDF
  donatedItems               DonatedItem[]
  // Feature #46: Treasure Typology Classifier — collector category classification
  typology                   ItemTypology?
  // Feature #70: Consignment — operator-consigned items with split payout
  consignorId                String? // Optional: consignor user ID (nullable for future Consignor table)
  consignmentSplitPct        Decimal? // Optional: percentage split for consignor (e.g., 0.70 = 70%)
  consignor                  User?                  @relation("ConsignedItems", fields: [consignorId], references: [id])
  // Feature #81: Persistent Inventory — items that recur across sales
  persistentInventory        Boolean                @default(false) // Pre-wire: persistent inventory feature activation
  isPersistent               Boolean                @default(false)
  // Feature #84: Master Item Library — canonical item definitions
  masterItemLibraryId        String? // Pre-wire: FK to future MasterItemLibrary model
  // Feature #136: QR Code Auto-Embedding in Photo Exports
  qrEmbedEnabled             Boolean                @default(true) // Embed QR code linking to item in exported photos
  // Feature #103: Photo Retention — archive old photos, delete very old ones
  archivedAt                 DateTime? // When photos were archived (90+ days after sale end)
  deletedFromCloudinary      Boolean                @default(false) // Whether original photo was deleted from Cloudinary (365+ days)
  // #112 Soft-Delete Archival + #121 Tiered Storage pre-wire
  deletedAt                  DateTime?
  storageArchive             Boolean                @default(false) // #121: Pre-wire for cold storage tier
  // Feature #91: Auto-Markdown (Smart Clearance)
  priceBeforeMarkdown        Float? // Original price before markdown applied
  markdownApplied            Boolean                @default(false) // Whether auto-markdown has been applied
  // Feature #228: Settlement Hub — high-value item tracking + AI comp
  isHighValue                Boolean                @default(false)
  highValueThreshold         Decimal?
  estimatedValue             Decimal?
  aiSuggestedPrice           Decimal?
  // Feature #371: Auto High-Value Item Flagging
  highValueSource            String?                @default("MANUAL") // "AUTO" | "MANUAL"
  highValueFlaggedAt         DateTime?
  isHighValueLocked          Boolean                @default(false) // Organizer locked decision, respect it
  saleTransactions           SaleTransaction[]
  // Feature #244 Phase 2: eBay listing tracking
  ebayListingId              String? // eBay listing ID after successful publish; used for Phase 3 sync
  ebayOfferId                String? // eBay offer ID from Inventory API; used to withdraw listing when item sells on FindA.Sale
  ebayCategoryId             String? // eBay numeric CategoryID captured on import from <PrimaryCategory><CategoryID> — used directly on push-back so 25021 (invalid condition for category) doesn't fire on leaf-only categories
  ebayCategoryName           String? // eBay leaf category name (e.g. "Guitar Amplifiers") — user-friendly display name for eBay category selected
  ebayNeedsReview            Boolean               @default(false) // Set true when all category suggestions fail 25005 — organizer must set category manually
  listedOnEbayAt             DateTime? // Timestamp when item was pushed to eBay
  // Feature #244 Phase 3: Post-sale eBay push — shipping classification
  ebayShippingClassification String                 @default("UNKNOWN") // SHIPPABLE | HEAVY_OVERSIZED | FRAGILE | UNKNOWN — auto-classified from category + tags
  ebayShippingOverride       String? // SHIPPABLE | LOCAL_PICKUP_ONLY | DONT_LIST — organizer override (null = use classification)
  // D-XP-003: Organizer-funded item discounts
  organizerDiscountXp        Int?                   @default(0) // XP spent to create discount (0 = no discount)
  organizerDiscountAmount    Decimal?               @db.Decimal(10, 2) // Dollar amount of discount ($2, $4, or $5 max)
  // Phase 2b: Legendary Early Access — Explorer's Guild rank perks
  isLegendary                Boolean                @default(false) // Organizer marks item as Legendary (exclusive early access)
  legendaryVisibleAt         DateTime? // When item becomes visible to all ranks (Sage+ see 4-6 hours earlier)
  legendaryPublishedAt       DateTime? // When organizer published this item as Legendary (audit trail)
  // ADR eBay Parity Phase B: Package dimensions for calculated shipping
  packageWeightOz            Int?
  packageLengthIn            Decimal?               @db.Decimal(6, 2)
  packageWidthIn             Decimal?               @db.Decimal(6, 2)
  packageHeightIn            Decimal?               @db.Decimal(6, 2)
  packageType                String? // BOX | LETTER | MAILING_TUBE | PACKAGE_THICK_ENVELOPE
  // ADR eBay Parity Phase B: Product identifiers for catalog match
  upc                        String?
  ean                        String?
  isbn                       String?
  mpn                        String?
  brand                      String?
  ebayEpid                   String?
  // ADR eBay Parity Phase B: Rich condition
  conditionNotes             String?
  // ADR eBay Parity Phase B: Pricing flexibility
  allowBestOffer             Boolean                @default(false)
  bestOfferAutoAcceptAmt     Decimal?               @db.Decimal(10, 2)
  bestOfferMinimumAmt        Decimal?               @db.Decimal(10, 2)
  // ADR eBay Parity Phase B: Listing extras
  ebaySecondaryCategoryId    String?
  ebaySubtitle               String?
  // Feature: Graceful Tier Degradation — grace lock status
  graceLockedAt              DateTime? // When item was locked due to tier downgrade
  graceLockedReason          String? // Reason for grace lock (e.g., "items_over_limit")
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  @@unique([saleId, sku])
  @@index([draftStatus])
  @@index([saleId, draftStatus])
  @@index([libraryId])
  @@index([organizerId, inInventory])
  @@index([isHighValue])
  @@index([ebayListingId])
  @@index([isLegendary, legendaryVisibleAt]) // Phase 2b: Legendary early access query optimization
}

// Camera Workflow v2: Photo model for multi-photo support (forward-looking schema)
model Photo {
  id                String   @id @default(cuid())
  itemId            String
  item              Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  url               String
  label             String? // "front" | "back" | "detail" — null for unlabeled (v3 future)
  isPrimary         Boolean  @default(false)
  autoEnhanced      Boolean  @default(false)
  backgroundRemoved Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([itemId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  saleId    String?
  sale      Sale?    @relation(fields: [saleId], references: [id])
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, saleId])
  @@unique([userId, itemId])
}

model Bid {
  id        String        @id @default(cuid())
  amount    Float
  status    String        @default("ACTIVE") // ACTIVE, WINNING, WON, LOST
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  itemId    String
  item      Item          @relation(fields: [itemId], references: [id])
  ipRecords BidIpRecord[] // Platform Safety #94: IP tracking for shill detection
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ADR-013 Phase 2: Proxy bidding (max bid auction)
model MaxBidByUser {
  id        String   @id @default(cuid())
  itemId    String
  userId    String
  maxAmount Float
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, userId])
}

model Purchase {
  id                    String            @id @default(cuid())
  amount                Float
  platformFeeAmount     Float?
  status                String            @default("PENDING") // PENDING, PAID, REFUNDED, FAILED, DISPUTED
  userId                String? // Nullable: POS walk-in buyers have no FindA.Sale account
  user                  User?             @relation(fields: [userId], references: [id])
  itemId                String?
  item                  Item?             @relation(fields: [itemId], references: [id])
  saleId                String?
  sale                  Sale?             @relation(fields: [saleId], references: [id])
  stripePaymentIntentId String? // Not unique — one PI may have multiple Purchase rows (multi-item cart)
  affiliateLinkId       String?
  affiliateLink         AffiliateLink?    @relation(fields: [affiliateLinkId], references: [id])
  source                String            @default("ONLINE") // ONLINE | POS
  buyerEmail            String? // POS only: optional email for receipt delivery
  digitalReceipt        DigitalReceipt?
  returnRequests        ReturnRequest[]
  checkoutEvidence      CheckoutEvidence? // Platform Safety #98: Chargeback defense documentation
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([stripePaymentIntentId])
}

model SaleSubscriber {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([saleId, userId])
  @@unique([saleId, phone])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  iconUrl     String?
  criteria    Json // conditions for earning the badge
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Review {
  id               String       @id @default(cuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  saleId           String
  sale             Sale         @relation(fields: [saleId], references: [id])
  rating           Int
  comment          String?
  response         String?
  respondedAt      DateTime?
  votes            ReviewVote[]
  verifiedPurchase Boolean      @default(false) // #115: Verified buyer badge
  timingFlag       String? // #116: 'RAPID' | 'BULK' — anomaly flags
  reviewerIp       String? // #116: IP address for bulk-review detection
  moderationStatus String       @default("APPROVED") // #116: 'PENDING' | 'APPROVED' | 'REJECTED'
  createdAt        DateTime     @default(now())

  @@index([moderationStatus])
}

model ReviewVote {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpful   Boolean
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("ReferrerToReferred", fields: [referrerId], references: [id])
  referredUserId String   @unique
  referredUser   User     @relation("ReferredToReferrer", fields: [referredUserId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([referrerId, referredUserId])
}

model AffiliateLink {
  id          String     @id @default(cuid())
  userId      String
  saleId      String
  clicks      Int        @default(0)
  conversions Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  sale        Sale       @relation(fields: [saleId], references: [id])
  purchases   Purchase[]

  @@unique([userId, saleId])
}

// Feature #84: Affiliate Code — Referral code generation for organizers
model AffiliateCode {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model LineEntry {
  id         String    @id @default(cuid())
  saleId     String
  sale       Sale      @relation(fields: [saleId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  position   Int
  status     String    @default("WAITING") // WAITING, NOTIFIED, ENTERED, CANCELLED
  notifiedAt DateTime?
  enteredAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([saleId, userId])
}

// Phase 19: Hunt Pass — shopper points ledger
model PointsTransaction {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String // "VISIT", "FAVORITE", "PURCHASE", "SHARE", "REVIEW", "COUPON_GENERATE", "RARITY_BOOST", "HUNT_PASS_DISCOUNT_REDEEM", "TRAIL_STOP_CHECKIN", "TRAIL_COMPLETION"
  points      Int
  saleId      String?
  itemId      String?
  purchaseId  String? // P0 Exploit Fix: Link to purchase for chargeback XP claw-back
  couponId    String? // Phase 2a: For COUPON_GENERATE sink type
  coupon      Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)
  boostType   String? // Phase 2a: For RARITY_BOOST type (e.g., "SALE_SPECIFIC")
  boostPct    Int? // Phase 2a: Boost percentage (e.g., +2)
  expiresAt   DateTime? // Phase 2a: For boost window expiration
  holdUntil   DateTime? // P0 Exploit Fix: XP not spendable until this time (72h for purchases, 30d for HP churn)
  description String?
  createdAt   DateTime  @default(now())

  @@index([userId, type])
  @@index([type])
  @@index([purchaseId])
  @@index([userId, holdUntil])
}

// Phase 20: Shopper messaging — conversation thread per shopper+organizer+sale
model Conversation {
  id            String    @id @default(cuid())
  saleId        String?
  sale          Sale?     @relation(fields: [saleId], references: [id])
  shopperUserId String
  shopperUser   User      @relation("ShopperConversations", fields: [shopperUserId], references: [id])
  organizerId   String
  organizer     Organizer @relation(fields: [organizerId], references: [id])
  messages      Message[]
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shopperUserId, organizerId, saleId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
}

// Phase 17: Shopper follows an organizer
model Follow {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id])
  // Notification preferences
  notifyEmail Boolean   @default(true)
  notifyPush  Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([userId, organizerId])
}

// Phase 21: Item reservation/hold system
model ItemReservation {
  id                  String       @id @default(cuid())
  itemId              String       @unique // one active hold per item
  item                Item         @relation(fields: [itemId], references: [id])
  userId              String
  user                User         @relation(fields: [userId], references: [id])
  status              String       @default("PENDING") // PENDING, CONFIRMED, HOLD_IN_CART, CANCELLED, EXPIRED, INVOICE_ISSUED
  expiresAt           DateTime
  holdDurationMinutes Int          @default(30) // Snapshot of user's rank-based duration at hold creation time
  note                String?
  // Hold-specific enhancements (Feature #121)
  gpsLatitude         Float? // GPS location at hold creation
  gpsLongitude        Float? // GPS location at hold creation
  qrScanId            String? // Fraud detection: which QR scan validated this hold
  fraudScore          Float        @default(0.0) // Fraud detection score (0.0-1.0)
  fraudFlags          String[]     @default([]) // Fraud red flags: HIGH_VELOCITY, SUSPICIOUS_PATTERN, etc.
  enRoute             Boolean      @default(false) // Feature #121: shopper was outside geofence but within 10mi (en route grace)
  invoiceId           String?      @unique // FK to HoldInvoice (optional, set when invoice created)
  invoice             HoldInvoice? // relation
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

// Hold-to-Pay feature: Payment invoice for held items
model HoldInvoice {
  id                    String           @id @default(cuid())
  reservationId         String?          @unique
  reservation           ItemReservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  shopperUserId         String
  shopper               User             @relation("ShopperInvoices", fields: [shopperUserId], references: [id], onDelete: Cascade)
  organizerUserId       String
  organizer             User             @relation("OrganizerInvoices", fields: [organizerUserId], references: [id], onDelete: Cascade)
  saleId                String
  sale                  Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  stripeSessionId       String?          @unique // Stripe Checkout session ID
  stripePaymentIntentId String?          @unique // Stripe payment intent ID
  status                InvoiceStatus    @default(PENDING)
  totalAmount           Int // in cents
  platformFeeAmount     Int // in cents (deducted from organizer payout)
  stripeFeeAmount       Int? // in cents (estimated Stripe processing fee)
  itemIds               String[] // all item IDs included in this invoice
  expiresAt             DateTime // = ItemReservation.expiresAt at time of invoice creation
  paidAt                DateTime?
  releasedAt            DateTime?
  // POS Cart feature: Multi-source invoices with split cash payment
  invoiceMode           String           @default("QUICK") // "QUICK" (15 min) or "TRUST" (organizer-set hours)
  cashAmountCents       Int? // Optional: cash collected by organizer at POS
  cardAmountCents       Int? // Optional: remainder charged via Stripe (total - cash)
  cartSessionId         String? // Optional: FK to POSSession for audit trail
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([saleId, status])
  @@index([shopperUserId])
  @@index([organizerUserId])
  @@index([expiresAt])
  @@index([cartSessionId])
}

// Feature #121: Sale Check-in — per-shopper GPS-based validation for hold rank enforcement
model SaleCheckin {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  latitude  Float
  longitude Float
  qrScanned Boolean  @default(false) // did user scan QR to verify?
  qrScanId  String? // links to future TreasureHuntQRScan or equivalent QR record
  checkinAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([saleId, userId]) // one check-in per shopper per sale
  @@index([saleId, checkinAt])
  @@index([userId])
}

// Feature #121: Organizer hold settings
model OrganizerHoldSettings {
  id                      String    @id @default(cuid())
  organizerId             String    @unique
  organizer               Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  // Rank-based hold allocation
  maxHoldsPerRank         Int       @default(3) // max items first-arriver can hold
  enableGpsValidation     Boolean   @default(false) // require GPS check-in near sale
  enableQrValidation      Boolean   @default(false) // require QR scan to confirm hold
  // Anti-fraud settings
  maxHoldsPerSession      Int       @default(10) // max total holds per shopper per visit
  fraudCheckEnabled       Boolean   @default(true) // run synchronous fraud detector
  autoSuspendThreshold    Float     @default(0.85) // auto-suspend holds > this fraud score
  // Hold-to-Pay feature settings
  flashLiquidationEnabled Boolean   @default(false) // organizer opt-in for flash liquidation after hold expires without payment
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

// V3: UGC missing-listing bounties
// Shoppers flag items they couldn't find at a sale; organizers can fulfill by listing the item.
model MissingListingBounty {
  id           String             @id @default(cuid())
  saleId       String?
  sale         Sale?              @relation(fields: [saleId], references: [id], onDelete: SetNull)
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  description  String? // What the shopper is looking for
  offerPrice   Float? // What they'd pay if listed
  status       String             @default("OPEN") // OPEN, FULFILLED, CANCELLED
  itemId       String? // Linked by organizer when fulfilled
  item         Item?              @relation(fields: [itemId], references: [id])
  crewId       String?
  crew         Crew?              @relation(fields: [crewId], references: [id], onDelete: SetNull)
  xpReward     Int                @default(25) // XP earned by organizer if submission purchased
  expiry       DateTime? // Auto-expire bounty (null = no auto-expire for backward compat)
  submissions  BountySubmission[] // All submissions for this bounty
  // Shopper-first bounty fields
  itemName     String? // Item name for shopper-created bounties
  category     String? // Category for shopper-created bounties
  maxBudget    Float? // Max budget for shopper-created bounties
  radiusMiles  Int? // Search radius in miles for shopper-created bounties
  referenceUrl String? // URL to reference photo or similar item link
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([saleId, status])
  @@index([userId])
  @@index([status, expiry])
  @@index([category, radiusMiles])
}

model BountySubmission {
  id             String               @id @default(cuid())
  bountyId       String
  bounty         MissingListingBounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  organizerId    String // User.id of organizer submitting
  organizer      User                 @relation("OrganizerSubmissions", fields: [organizerId], references: [id])
  itemId         String
  item           Item                 @relation("BountySubmissions", fields: [itemId], references: [id])
  status         String               @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, REJECTED, EXPIRED, PURCHASED
  shopperMessage String? // Message from organizer to shopper (500 char limit)
  submittedAt    DateTime             @default(now())
  reviewedAt     DateTime? // When shopper approved/rejected
  expiresAt      DateTime // Auto-expiry: submittedAt + 3 days
  purchasedAt    DateTime?
  updatedAt      DateTime             @updatedAt

  @@index([bountyId, status])
  @@index([organizerId])
  @@index([expiresAt])
  @@index([status])
}

// X1: Zapier / webhook registrations — organizer registers a URL + event list
model Webhook {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  url       String
  events    String[] // e.g. ["bid.placed","purchase.completed","sale.published"]
  secret    String // HMAC-SHA256 signing secret
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Feature #85: Treasure Hunt QR — Per-sale, organizer-created scavenger hunt
model TreasureHuntQRClue {
  id        String               @id @default(cuid())
  saleId    String
  sale      Sale                 @relation(fields: [saleId], references: [id], onDelete: Cascade)
  clueText  String
  hintPhoto String?
  category  String?
  createdAt DateTime             @default(now())
  scans     TreasureHuntQRScan[]

  @@index([saleId])
}

model TreasureHuntQRScan {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation("TreasureHuntQRScans", fields: [userId], references: [id], onDelete: Cascade)
  clueId    String
  clue      TreasureHuntQRClue @relation(fields: [clueId], references: [id], onDelete: Cascade)
  itemId    String?
  item      Item?              @relation("TreasureHuntQRScans", fields: [itemId], references: [id], onDelete: SetNull)
  scannedAt DateTime           @default(now())

  @@unique([userId, clueId])
  @@index([clueId])
}

// CD2 Phase 2: Daily Treasure Hunt
model TreasureHunt {
  id          Int                @id @default(autoincrement())
  date        String             @unique // YYYY-MM-DD
  clue        String
  category    String
  keywords    String[]
  pointReward Int                @default(50)
  createdAt   DateTime           @default(now())
  finds       TreasureHuntFind[]
}

model TreasureHuntFind {
  id      Int          @id @default(autoincrement())
  userId  String
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  huntId  Int
  hunt    TreasureHunt @relation(fields: [huntId], references: [id], onDelete: Cascade)
  itemId  String
  item    Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  foundAt DateTime     @default(now())

  @@unique([userId, huntId])
}

// ST4: Stripe webhook event deduplication
model StripeEvent {
  id          String   @id
  processedAt DateTime @default(now())

  @@index([processedAt])
}

// CD2 Phase 2: Streak Challenges — tracks daily streaks by type (visit, save, buy)
model UserStreak {
  id               Int       @id @default(autoincrement())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String // 'visit' | 'save' | 'buy'
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime?
  updatedAt        DateTime  @updatedAt

  @@unique([userId, type])
}

// Flash Deals — time-limited promotions on specific items
model FlashDeal {
  id          String   @id @default(uuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  discountPct Int // e.g. 25 = 25% off
  startsAt    DateTime
  endsAt      DateTime
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

// Occasion-based wishlists for shoppers
model Wishlist {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // "Moving to New Place", "Home Office", etc.
  occasion  String? // "moving" | "downsizing" | "decorating" | "gifting" | "other"
  isPublic  Boolean        @default(false)
  shareSlug String?        @unique
  items     WishlistItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model WishlistItem {
  id         String   @id @default(uuid())
  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  itemId     String
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  note       String?
  addedAt    DateTime @default(now())

  @@unique([wishlistId, itemId])
}

// Group Buying Pools — allow shoppers to co-purchase expensive items
model BuyingPool {
  id           String            @id @default(cuid())
  itemId       String
  item         Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  creatorId    String
  creator      User              @relation("CreatedPools", fields: [creatorId], references: [id], onDelete: Cascade)
  targetAmount Int // total item price in cents
  status       String            @default("OPEN") // OPEN | FILLED | CANCELLED | COMPLETED
  expiresAt    DateTime
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants PoolParticipant[]
}

model PoolParticipant {
  id           String     @id @default(cuid())
  poolId       String
  pool         BuyingPool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation("PoolParticipations", fields: [userId], references: [id], onDelete: Cascade)
  pledgeAmount Int // in cents
  joinedAt     DateTime   @default(now())

  @@unique([poolId, userId])
}

// Notification Inbox — stores all in-app notifications (sale alerts, purchases, messages, flash deals, etc.)
model Notification {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                String // "sale_alert" | "purchase" | "message" | "flash_deal" | "badge" | "system"
  title               String
  body                String
  link                String? // optional deep link e.g. "/sales/abc123"
  read                Boolean  @default(false)
  notificationChannel String   @default("IN_APP") // Feature #72 Phase 2: "IN_APP" | "EMAIL" | "PUSH"
  channel             String   @default("OPERATIONAL") // Feature #73: "OPERATIONAL" | "DISCOVERY"
  createdAt           DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

// Feature: Abandoned Checkout Recovery — track in-progress payment intents for recovery emails
model CheckoutAttempt {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId            String
  item              Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  paymentIntent     String    @unique
  recoveryEmailSent Boolean   @default(false)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())

  @@index([completedAt, recoveryEmailSent])
}

// Feature: Item Waitlist / "Notify Me" — join waitlist for SOLD/ON_HOLD items
model ItemWaitlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
}

// Pickup Appointment Scheduling — organizers set available pickup time slots; shoppers book them
model PickupSlot {
  id        String          @id @default(uuid())
  saleId    String
  sale      Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  capacity  Int             @default(1)
  bookings  PickupBooking[]
  createdAt DateTime        @default(now())
}

model PickupBooking {
  id        String     @id @default(uuid())
  slotId    String
  slot      PickupSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     String?
  createdAt DateTime   @default(now())

  @@unique([slotId, userId])
}

// In-app feedback widget for beta testers
model Feedback {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  rating    Int? // 1-5 (nullable: some surveys use text answers only)
  text      String?
  page      String?
  userAgent String?

  // Feature: Feedback context for survey tracking
  surveyType     String? // "OG-1", "SH-2", null for legacy static form
  deviceType     String? // "mobile", "desktop"
  userTierAtTime String? // e.g., "SIMPLE", "PRO", null if not applicable

  createdAt DateTime @default(now())

  // Optional: for analytics speed
  @@index([surveyType, createdAt])
  @@index([userId, surveyType])
}

// Feature: Feedback Suppression — user opt-out tracking
model FeedbackSuppression {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveyType   String
  suppressedAt DateTime @default(now())

  @@unique([userId, surveyType])
  @@index([userId])
}

// Beta Invite Code System — Patrick controls organizer access during beta
model BetaInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  email     String? // Optional: can restrict invite to specific email
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  usedById  String?   @unique // One-to-one: user can only use one invite
  usedBy    User?     @relation(fields: [usedById], references: [id], onDelete: SetNull)
}

// Saved Searches — shoppers can save search filters for quick re-runs and alerts
model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  filters     Json // Stored search filters: { q, category, radius, lat, lng, priceMin, priceMax, condition, saleStatus, dateFrom, dateTo }
  notifyOnNew Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Sale RSVP — shoppers can RSVP to attend a sale ("Going to this sale" feature)
model SaleRSVP {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([saleId, userId])
}

// Organizer Referral Program — organizers refer other organizers
model OrganizerReferral {
  id           String    @id @default(cuid())
  referrerId   String
  referrer     User      @relation("ReferrerOrganizer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId    String    @unique
  referee      User      @relation("RefereeOrganizer", fields: [refereeId], references: [id], onDelete: Cascade)
  status       String    @default("PENDING") // PENDING | CREDITED
  creditAmount Float? // Amount credited (in dollars, not cents)
  createdAt    DateTime  @default(now())
  creditedAt   DateTime?

  @@unique([referrerId, refereeId])
}

// Sale Templates — reusable sale setup configurations for organizers
model SaleTemplate {
  id           String    @id @default(cuid())
  organizerId  String
  organizer    Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  defaultItems Json? // Default item categories/conditions to pre-populate
  settings     Json? // Sale settings: pickup slots, shipping options, etc.
  usedCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([organizerId])
}

// Token-based email unsubscribe system — type-specific unsubscribe tokens
model UnsubscribeToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  type      String // "all" | "weekly" | "flash" | "newSales" | "priceDrops" | "messages"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// A/B Testing — lightweight framework for CTA variants
model ABTestAssignment {
  id        String   @id @default(cuid())
  sessionId String // anonymous session cookie ID
  testName  String
  variant   String
  createdAt DateTime @default(now())

  @@unique([sessionId, testName])
}

model ABTestEvent {
  id        String   @id @default(cuid())
  sessionId String
  testName  String
  variant   String
  event     String // "view" | "click" | "signup" | "conversion"
  createdAt DateTime @default(now())

  @@index([testName, variant, event])
}

// Sale Day-Of Checklist — organizers' pre-sale, during-sale, and post-sale task list
model SaleChecklist {
  id        String   @id @default(cuid())
  saleId    String   @unique
  items     Json // Array of { id: string; phase: "pre" | "during" | "post"; label: string; completed: boolean; completedAt?: string }
  updatedAt DateTime @updatedAt
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

// Buyer Protection / Dispute Resolution — track item condition mismatches and issues
model Dispute {
  id          String   @id @default(cuid())
  orderId     String // references Order or transaction ID
  buyerId     String
  sellerId    String
  saleId      String
  itemId      String
  reason      String // "condition_mismatch" | "item_missing" | "wrong_item" | "other"
  description String
  status      String   @default("open") // "open" | "under_review" | "resolved" | "closed"
  resolution  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  buyer       User     @relation("DisputeBuyer", fields: [buyerId], references: [id])
  seller      User     @relation("DisputeSeller", fields: [sellerId], references: [id])

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
}

// Organizer Quick-Reply Templates for shopper messages
model MessageTemplate {
  id          String   @id @default(cuid())
  organizerId String
  title       String
  body        String
  category    String   @default("general") // "pricing" | "pickup" | "availability" | "general"
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  organizer   User     @relation("OrganizerTemplates", fields: [organizerId], references: [id], onDelete: Cascade)

  @@index([organizerId])
}

// Batch 17: Item Price History — tracks price changes over time
model ItemPriceHistory {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  price     Float
  changedBy String // "organizer" | "auction" | "reverseAuction" | "flashDeal"
  note      String?
  createdAt DateTime @default(now())

  @@index([itemId])
}

// Sprint 3: Shopper Loyalty Coupons — issued after each completed purchase
model Coupon {
  id                 String              @id @default(cuid())
  code               String              @unique
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  discountType       String // "PERCENT" | "FIXED"
  discountValue      Float // 5.00 = $5 off; 10 = 10% off
  minPurchaseAmount  Float? // null = no minimum
  maxDiscountAmount  Float? // cap for PERCENT coupons; null = uncapped
  status             String              @default("ACTIVE") // "ACTIVE" | "USED" | "EXPIRED"
  sourcePurchaseId   String? // which purchase earned this coupon
  redeemedPurchaseId String? // which purchase this was applied to
  expiresAt          DateTime
  usedAt             DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  xpSpent            Int? // Phase 2a: XP cost if this coupon was generated via XP sink (20 XP typical)
  pointsTransactions PointsTransaction[] // Phase 2a: Reference from PointsTransaction via couponId
  // Phase 2b: Shopper self-service XP coupon tiers
  generatedFromXp    Boolean             @default(false) // true = shopper spent XP to generate this; false = organizer-issued or loyalty
  xpTier             String? // "DOLLAR_OFF_TEN" | "ONE_FIFTY_OFF_TWENTY" | "FIVE_OFF_FIFTY" (null for organizer coupons)

  @@index([userId, status])
  @@index([code])
}

// Phase 2a: Rarity Boost — shopper spends 15 XP to boost legendary find odds for a specific sale
model RarityBoost {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation("RarityBoosts", fields: [userId], references: [id], onDelete: Cascade)
  saleId    String
  sale      Sale      @relation("RarityBoosts", fields: [saleId], references: [id], onDelete: Cascade)
  boostPct  Int       @default(2) // Phase 2a: +2% rarity boost for this sale
  expiresAt DateTime // Phase 2a: Sale end time (boost expires when sale closes)
  usedAt    DateTime? // Phase 2a: When claimed (null = not yet claimed)
  createdAt DateTime  @default(now())

  @@unique([userId, saleId])
  @@index([userId, expiresAt])
  @@index([saleId])
}

// Batch 17: Sale Waitlist — notify shoppers when new items added to a sale
model SaleWaitlist {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([saleId, userId])
  @@index([saleId])
}

// Sale Reminders — email reminders for upcoming sales
model SaleReminder {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  saleId       String
  sale         Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  reminderType String    @default("email") // "email" | "push" — type of reminder
  status       String    @default("ACTIVE") // "ACTIVE" | "SENT" | "CANCELLED"
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, saleId, reminderType])
  @@index([userId])
  @@index([saleId])
}

// B1 ADR: Fee Structure — configurable platform fees by listing type (or global default)
model FeeStructure {
