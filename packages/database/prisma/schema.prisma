// Feature #45: Collector Passport — identity-based collection tracking
// Shoppers define what they collect with keywords + categories, get personalized alerts
model CollectorPassport {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Collector identity
  bio         String?  // "Passionate collector of mid-century modern furniture"
  specialties String[] // ["mid-century modern", "depression glass", "fiestaware"]
  categories  String[] // ["Furniture", "Kitchenware", "Art & Decor"]
  keywords    String[] // ["eames", "pyrex", "homer laughlin", "walnut"]

  // Notification preferences
  notifyEmail Boolean  @default(true)
  notifyPush  Boolean  @default(true)

  // Stats (computed fields updated periodically)
  totalFinds  Int      @default(0)  // number of matching items purchased
  isPublic    Boolean  @default(true) // can other shoppers view this collector's profile

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Feature #47: UGC Photo Tags — user-generated content with tagging and moderation
model UGCPhoto {
