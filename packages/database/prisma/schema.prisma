generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String
  role          String     @default("USER") // USER, ORGANIZER, ADMIN
  points        Int        @default(0)
  phone         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  referralCode      String?    @unique
  resetToken        String?    @unique
  resetTokenExpiry  DateTime?
  organizer         Organizer?
  purchases     Purchase[]
  favorites     Favorite[]
  bids          Bid[]
  subscriptions SaleSubscriber[]
  userBadges    UserBadge[]
  referredUsers   Referral[]      @relation("ReferrerToReferred")
  referredBy      Referral?       @relation("ReferredToReferrer")
  lineEntries     LineEntry[]
  reviews           Review[]
  affiliateLinks    AffiliateLink[]
  pushSubscriptions PushSubscription[]
  following         Follow[]
}

model Organizer {
  id              String   @id @default(cuid())
  businessName    String
  phone           String
  address         String
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  sales           Sale[]
  stripeConnectId String?
  // Phase 17: Reputation
  reputationTier  String   @default("NEW") // NEW, TRUSTED, ESTATE_CURATOR
  avgRating       Float?
  totalReviews    Int      @default(0)
  totalSales      Int      @default(0)
  followers       Follow[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sale {
  id            String     @id @default(cuid())
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime
  address       String
  city          String
  state         String
  zip           String
  lat           Float
  lng           Float
  photoUrls     String[]
  tags          String[]
  status        String     @default("DRAFT") // DRAFT, PUBLISHED, ENDED
  isAuctionSale Boolean    @default(false)
  qrScanCount   Int        @default(0)
  organizerId   String
  organizer     Organizer  @relation(fields: [organizerId], references: [id])
  items         Item[]
  favorites     Favorite[]
  subscribers   SaleSubscriber[]
  affiliateLinks AffiliateLink[]
  lineEntries   LineEntry[]
  purchases     Purchase[]
  reviews       Review[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Item {
  id               String    @id @default(cuid())
  title            String
  description      String?
  price            Float?
  auctionStartPrice Float?
  currentBid       Float?
  bidIncrement     Float?    @default(1)
  auctionEndTime   DateTime?
  status           String    @default("AVAILABLE") // AVAILABLE, SOLD, RESERVED, AUCTION_ENDED
  category         String?   // furniture, decor, vintage, textiles, collectibles, art, antiques, jewelry, books, tools, electronics, clothing, home, other
  condition        String?   // mint, excellent, good, fair, poor
  photoUrls        String[]
  saleId           String
  sale             Sale      @relation(fields: [saleId], references: [id])
  bids             Bid[]
  purchases        Purchase[]
  favorites        Favorite[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  saleId    String?
  sale      Sale?    @relation(fields: [saleId], references: [id])
  itemId    String?
  item      Item?    @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, saleId])
  @@unique([userId, itemId])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Float
  status    String   @default("ACTIVE") // ACTIVE, WINNING, WON, LOST
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Purchase {
  id                    String         @id @default(cuid())
  amount                Float
  platformFeeAmount     Float?
  status                String         @default("PENDING") // PENDING, PAID, REFUNDED
  userId                String
  user                  User           @relation(fields: [userId], references: [id])
  itemId                String?
  item                  Item?          @relation(fields: [itemId], references: [id])
  saleId                String?
  sale                  Sale?          @relation(fields: [saleId], references: [id])
  stripePaymentIntentId String?        @unique
  affiliateLinkId       String?
  affiliateLink         AffiliateLink? @relation(fields: [affiliateLinkId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model SaleSubscriber {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  saleId    String
  sale      Sale      @relation(fields: [saleId], references: [id])
  phone     String?
  email     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([saleId, userId])
  @@unique([saleId, phone])
}

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  iconUrl     String?
  criteria    Json     // conditions for earning the badge
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userBadges  UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  referrer       User     @relation("ReferrerToReferred", fields: [referrerId], references: [id])
  referredUserId String   @unique
  referredUser   User     @relation("ReferredToReferrer", fields: [referredUserId], references: [id])
  createdAt      DateTime @default(now())

  @@unique([referrerId, referredUserId])
}

model AffiliateLink {
  id          String     @id @default(cuid())
  userId      String
  saleId      String
  clicks      Int        @default(0)
  conversions Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
  sale        Sale       @relation(fields: [saleId], references: [id])
  purchases   Purchase[]

  @@unique([userId, saleId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
}

model LineEntry {
  id         String   @id @default(cuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  position   Int
  status     String   @default("WAITING") // WAITING, NOTIFIED, ENTERED, CANCELLED
  notifiedAt DateTime?
  enteredAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([saleId, userId])
}

// Phase 17: Shopper follows an organizer
model Follow {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id])
  // Notification preferences
  notifyEmail Boolean   @default(true)
  notifyPush  Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@unique([userId, organizerId])
}
