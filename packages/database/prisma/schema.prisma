  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId          String?
  item            Item?      @relation(fields: [itemId], references: [id], onDelete: SetNull)
  saleId          String?
  sale            Sale?      @relation(fields: [saleId], references: [id], onDelete: SetNull)
  photoUrl        String
