// Feature #48: Treasure Trail Route Builder — shopper's custom route through multiple sales
model TreasureTrail {
  id          String     @id @default(cuid())
  // Legacy route-based trail (V1)
  userId      String
  user        User       @relation("UserTrails", fields: [userId], references: [id], onDelete: Cascade)
  // New discovery-based trail (V2) — organizer-anchored
  organizerId String? // Organizer who created the trail (V2 only; null for legacy V1)
  organizer   Organizer? @relation("OrganizerTrails", fields: [organizerId], references: [id], onDelete: Restrict)
  saleId      String? // Anchored sale (V2 only; null for legacy V1)
  sale        Sale?      @relation("SaleTrails", fields: [saleId], references: [id], onDelete: Cascade)

  // Trail metadata
  name         String
  description  String? @db.VarChar(500)
  heroImageUrl String? // Cloudinary URL for trail card display

  // Trail type: "DISCOVERY" (V2 local POI tour) or "ROUTE" (V1 multi-sale route)
  type String @default("ROUTE")

  // Legacy route-specific fields (V1)
  stopsJson        Json      @default("[]") @map("stops") // V1 legacy: [{saleId, order, timeEstimateMin, highlightItemIds: []}]
  totalDistanceKm  Float? // Cached from OSRM call
  totalDurationMin Int? // Cached from OSRM call
  completedSaleIds String[]  @default([])
  isCompleted      Boolean   @default(false)
  completedAt      DateTime?

  // Discovery-specific fields (V2)
  minStopsRequired Int @default(3) // Minimum stops to complete
  maxStops         Int @default(7) // Max stops (affects bonus scaling)
  windowDays       Int @default(7) // Days to complete from first check-in

  // Completion tracking
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false) // Platform-curated featured trails
  isPublic   Boolean @default(false)
  shareToken String? @unique @db.VarChar(32) // Random token for public link

  // Stats
  viewCount       Int      @default(0)
  completionCount Int      @default(0)
  avgRating       Decimal? // Shopper ratings post-completion

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  highlights  TrailHighlight[]
  stops       TrailStop[] // New V2 stops (distinct from legacy stops_json)
  checkIns    TrailCheckIn[]
  completions TrailCompletion[]
  ratings     TrailRating[]

  @@index([userId])
  @@index([organizerId])
  @@index([saleId])
  @@index([isPublic, isFeatured])
  @@index([type])
}

// Feature #48: Treasure Trails — individual stops on a discovery trail
model TrailStop {
  id      String        @id @default(cuid())
  trailId String
  trail   TreasureTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)

  // Stop identification
  stopType        String // "SALE" | "RESALE_SHOP" | "LANDMARK" | "CAFE" | "PARTNER"
  stopName        String
  stopDescription String? @db.VarChar(300)
  address         String?

  // Geolocation
  latitude  Float
  longitude Float

  // External reference (if applicable)
  saleId        String? // For SALE type only
  sale          Sale?    @relation("SaleTrailStops", fields: [saleId], references: [id], onDelete: SetNull)
  googlePlaceId String? // For non-sale stops (RESALE_SHOP, LANDMARK, CAFE)
  googleRating  Decimal? // Cached from Places API
  googlePhone   String? // Cached from Places API

  // XP reward
  baseXp       Int // 5=sale, 3=resale, 2=POI, 4=partner (locked per type)
  photoXpBonus Int @default(2)

  // Sequence
  order Int // 0-based ordering in trail

  // Organizer note
  organizer_note String? @db.VarChar(200) // "Hidden gem", "Great coffee", etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  checkIns TrailCheckIn[]
  photos   TrailPhoto[]

  @@unique([trailId, order])
  @@index([trailId])
  @@index([stopType])
  @@index([googlePlaceId])
}

// Feature #48: Treasure Trails — user check-in at a stop
model TrailCheckIn {
  id      String        @id @default(cuid())
  trailId String
  trail   TreasureTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)
  stopId  String
  stop    TrailStop     @relation(fields: [stopId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // GPS data
  latitude  Float
  longitude Float

  // XP awarded
  baseXpAwarded  Int // Base per-stop XP
  photoXpAwarded Int @default(0) // 0 or 2 if photo posted

  // XP tracking
  // photoId removed — photos are queried via TrailPhoto.checkInId

  // Timing
  checkedInAt DateTime @default(now())
  createdAt   DateTime @default(now())

  // Relations
  photos TrailPhoto[] // Photos posted at this check-in

  @@unique([trailId, stopId, userId]) // One check-in per user per stop per trail
  @@index([trailId, userId])
  @@index([stopId])
  @@index([userId])
  @@index([checkedInAt])
}

// Feature #48: Treasure Trails — photos posted by shoppers at stops
model TrailPhoto {
  id        String       @id @default(cuid())
  checkInId String
  checkIn   TrailCheckIn @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  stopId    String
  stop      TrailStop    @relation(fields: [stopId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Photo storage
  cloudinaryUrl String // Cloudinary CDN URL
  cloudinaryId  String // For deletion reference

  // Social
  postedToFeed Boolean @default(true) // Shopper chose to share publicly
  likeCount    Int     @default(0)
  commentCount Int     @default(0)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([stopId])
  @@index([createdAt])
}

// Feature #48: Treasure Trails — completion tracking for user+trail
model TrailCompletion {
  id      String        @id @default(cuid())
  trailId String
  trail   TreasureTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Completion metadata
  completionBonusXp  Int // 40–80 XP based on stop count
  totalXpEarned      Int // Sum of all stop XP + bonus
  stopCountCompleted Int // Number of stops checked in
  photoCountPosted   Int // Number of photos posted

  firstCheckInAt DateTime // When user completed first stop
  completedAt    DateTime // When user completed last stop
  daysToComplete Int // Computed: (completedAt - firstCheckInAt).days

  rating Int? // 1-5 star rating post-completion
  review String? @db.VarChar(300)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trailId, userId])
  @@index([trailId])
  @@index([userId])
  @@index([completedAt])
}

// Feature #48: Treasure Trails — shopper ratings of trails
model TrailRating {
  id      String        @id @default(cuid())
  trailId String
  trail   TreasureTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating Int // 1–5
  review String? @db.VarChar(500)

  createdAt DateTime @default(now())

  @@unique([trailId, userId]) // One rating per user per trail
  @@index([trailId, rating])
}

// Feature #48: Track items highlighted on trails
model TrailHighlight {
  id        String        @id @default(cuid())
  trailId   String
  itemId    String
  saleId    String
  note      String?
  trail     TreasureTrail @relation(fields: [trailId], references: [id], onDelete: Cascade)
  item      Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([trailId, itemId])
  @@index([trailId])
  @@index([itemId])
}

// Feature #30: AI Item Valuation — comparable sales pricing
model ItemValuation {
  id              String   @id @default(cuid())
  itemId          String   @unique
  item            Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  priceLow        Float // cents
  priceHigh       Float // cents
  priceMedian     Float // cents (median of comparables)
  confidenceScore Int // 0-100 based on sample size
  comparableCount Int // Number of sold items used
  method          String   @default("STATISTICAL") // STATISTICAL | EMBEDDING
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([itemId])
  @@index([generatedAt])
}

// Feature #46: Treasure Typology Classifier — AI-powered item collector category classification
model ItemTypology {
  id     String @id @default(cuid())
  itemId String @unique
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Primary classification result
  primaryCategory     TypologyCategory
  primaryConfidence   Float // 0.0–1.0
  secondaryCategory   TypologyCategory?
  secondaryConfidence Float? // 0.0–1.0

  // Raw AI response for audit trail
  rawResponse Json? // Full Haiku response: { category, confidence, reasoning }

  // Organizer feedback & correction
  organizer_reviewed    Boolean           @default(false)
  organizer_correctedTo TypologyCategory?
  correctionReason      String? // Organizer note (diagnostic)

  classifiedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([itemId])
  @@index([primaryCategory])
}

// Feature #52: Estate Sale Encyclopedia — Crowdsourced knowledge base
model EncyclopediaEntry {
  id       String   @id @default(cuid())
  slug     String   @unique // URL-friendly: "depression-glass-101"
  title    String
  subtitle String?
  content  String // Markdown format
  category String // Art Deco, MCM, Americana, Victorian, Tools, Toys, etc.
  tags     String[] @default([])

  authorId String
  author   User   @relation("EncyclopediaAuthor", fields: [authorId], references: [id])

  status     String  @default("DRAFT") // DRAFT | PENDING_REVIEW | PUBLISHED | FLAGGED
  isFeatured Boolean @default(false)

  viewCount    Int @default(0)
  helpfulCount Int @default(0)

  // Versioning — keep full history of edits
  revisions EncyclopediaRevision[]

  // Price benchmarks
  benchmarks PriceBenchmark[]

  // External references
  references EncyclopediaReference[]

  // Vote tracking (one vote per user)
  votes EncyclopediaVote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@index([authorId])
}

model EncyclopediaRevision {
  id      String            @id @default(cuid())
  entryId String
  entry   EncyclopediaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  title    String
  content  String
  category String
  tags     String[]

  authorId String
  author   User   @relation("EncyclopediaRevisionAuthor", fields: [authorId], references: [id])

  changeNote String?

  createdAt DateTime @default(now())

  @@index([entryId])
  @@index([authorId])
}

model PriceBenchmark {
  id      String            @id @default(cuid())
  entryId String
  entry   EncyclopediaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  condition String // NEW | USED | REFURBISHED | PARTS_OR_REPAIR
  region    String // Northeast, Midwest, South, West, National

  priceRangeLow  Int
  priceRangeHigh Int

  dataSource String? // AskPrice, SOLD listing, Comps, Appraiser
  updatedAt  DateTime @updatedAt

  @@index([entryId])
}

model EncyclopediaReference {
  id      String            @id @default(cuid())
  entryId String
  entry   EncyclopediaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  title  String
  url    String
  source String? // Smithsonian, Museum of Modern Art, etc.

  createdAt DateTime @default(now())

  @@index([entryId])
}

model EncyclopediaVote {
  id      String            @id @default(cuid())
  entryId String
  entry   EncyclopediaEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("EncyclopediaVote", fields: [userId], references: [id])

  helpful Boolean // true = helpful, false = not helpful

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entryId, userId])
  @@index([entryId])
  @@index([userId])
}

// Feature #71: Organizer Reputation Score — computed from response time, sale frequency, photo quality
model OrganizerReputation {
  id              String   @id @default(cuid())
  organizerId     String   @unique
  organizer       User     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  score           Float    @default(0) // 0–5 star rating
  responseTimeAvg Float    @default(0) // average hours from inquiry to first reply (stub)
  saleCount       Int      @default(0) // total published sales count
  photoQualityAvg Float    @default(0) // average photos per item (0–1 scale, converted to 0–5)
  shopperRating   Float? // stub for future crowdsourced ratings
  disputeRate     Float    @default(0) // stub for future dispute tracking
  isNew           Boolean  @default(true) // true if saleCount < 3
  lastCalculated  DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizerId])
}

// Feature #54: Crowdsourced Appraisal API — Sprint 1
model AppraisalRequest {
  id                 String              @id @default(cuid())
  submittedByUserId  String
  submittedBy        User                @relation("AppraisalRequests", fields: [submittedByUserId], references: [id])
  itemTitle          String
  itemDescription    String?
  itemCategory       String?
  photos             AppraisalPhoto[]
  status             String              @default("PENDING") // PENDING | IN_REVIEW | COMPLETED | EXPIRED | DISPUTED
  communityResponses AppraisalResponse[] @relation("CommunityAppraisals")
  aiAppraisalRequest AppraisalAIRequest?
  consensus          AppraisalConsensus?
  disputes           AppraisalDispute[]
  expiresAt          DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([submittedByUserId])
  @@index([status])
}

model AppraisalPhoto {
  id            String           @id @default(cuid())
  requestId     String
  request       AppraisalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  cloudinaryUrl String
  uploadedAt    DateTime         @default(now())

  @@index([requestId])
}

model AppraisalResponse {
  id              String           @id @default(cuid())
  requestId       String
  request         AppraisalRequest @relation("CommunityAppraisals", fields: [requestId], references: [id], onDelete: Cascade)
  responderId     String
  responder       User             @relation("AppraisalResponses", fields: [responderId], references: [id])
  estimatedLow    Int
  estimatedHigh   Int
  confidence      String           @default("COMMUNITY")
  expertise       String?
  reasoning       String
  helpfulVotes    Int              @default(0)
  notHelpfulVotes Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([requestId, responderId])
  @@index([requestId])
  @@index([responderId])
}

model AppraisalConsensus {
  id              String           @id @default(cuid())
  requestId       String           @unique
  request         AppraisalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  finalLow        Int
  finalHigh       Int
  confidenceScore Int
  methodology     String
  aiModelVersion  String?
  aiConfidence    Float?
  responseCount   Int              @default(0)
  completedAt     DateTime         @default(now())

  @@index([requestId])
}

model AppraisalAIRequest {
  id                    String           @id @default(cuid())
  requestId             String           @unique
  request               AppraisalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId                String
  user                  User             @relation("AppraisalAIRequests", fields: [userId], references: [id])
  pricePaidCents        Int
  paymentStatus         String           @default("PENDING")
  stripePaymentIntentId String?
  completedAt           DateTime?
  expiresAt             DateTime
  createdAt             DateTime         @default(now())

  @@index([userId])
}

model AppraisalDispute {
  id             String           @id @default(cuid())
  requestId      String
  request        AppraisalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  raisedByUserId String
  raisedBy       User             @relation("AppraisalDisputes", fields: [raisedByUserId], references: [id])
  reason         String
  notes          String?
  status         String           @default("OPEN")
  resolution     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([requestId])
}

// Feature #51: Sale Ripples — social proof via activity ripples (views, shares, saves)
model SaleRipple {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  type      String   @default("VIEW") // VIEW | SHARE | SAVE | BID — activity type
  userId    String? // Optional: anonymous views won't have userId
  user      User?    @relation("SaleRipples", fields: [userId], references: [id])
  metadata  Json? // Optional metadata e.g., { source: "facebook", platform: "mobile" }
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// Feature #72: Affiliate Program — referral payouts and tracking
model AffiliatePayout {
  id             String    @id @default(cuid())
  referrerId     String // User who earned the payout (affiliate)
  referrer       User      @relation("AffiliatePayoutsGiven", fields: [referrerId], references: [id])
  referredUserId String? // Optional: user who was referred (null if campaign-wide payout)
  referredUser   User?     @relation("AffiliatePayoutsReceived", fields: [referredUserId], references: [id])
  saleId         String? // Optional: linked to a specific sale
  sale           Sale?     @relation(fields: [saleId], references: [id])
  amount         Decimal // Payout amount in USD
  status         String    @default("PENDING") // PENDING | PAID | CANCELLED
  paidAt         DateTime? // Timestamp when payout was processed
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([referrerId])
  @@index([referredUserId])
  @@index([saleId])
  @@index([status])
}

// Feature #72: Affiliate Referral tracking — tracks individual referral relationships
model AffiliateReferral {
  id                String    @id @default(cuid())
  referrerId        String // The User who referred
  referrer          User      @relation("AffiliateReferrals_Referrer", fields: [referrerId], references: [id])
  referredUserId    String // The User who was referred
  referredUser      User      @relation("AffiliateReferrals_Referred", fields: [referredUserId], references: [id])
  referralCode      String    @unique // The code used at signup
  status            String    @default("PENDING") // PENDING | QUALIFIED | PAID
  payoutAmountCents Int? // Amount in cents (nullable until payout calculated)
  paidAt            DateTime? // Timestamp when payout was processed
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([referrerId])
  @@index([referredUserId])
  @@index([referralCode])
  @@index([status])
}

// Feature #87: Brand & Designer Tracking
model BrandFollow {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandName   String
  notifyEmail Boolean  @default(true)
  notifyPush  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, brandName])
  @@index([userId])
}

// Platform Safety #94: Same-IP Bidder Detection
// Tracks IP addresses used when placing bids to detect shill rings
model BidIpRecord {
  id        String   @id @default(cuid())
  bidId     String
  bid       Bid      @relation(fields: [bidId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("BidIpRecords", fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String
  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([userId])
  @@index([bidId])
}

// Platform Safety #98: Chargeback Defense Documentation
// Stores checkout evidence for dispute resolution (timestamps, IP, acknowledgment)
model CheckoutEvidence {
  id                 String    @id @default(cuid())
  purchaseId         String    @unique
  purchase           Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  checkoutTimestamp  DateTime // When checkout was initiated
  emailSentAt        DateTime? // When confirmation email was sent
  checkoutIp         String? // Buyer's IP at checkout time
  acknowledgmentText String // Buyer's confirmation text (e.g., "I understand the buyer premium...")
  createdAt          DateTime  @default(now())

  @@index([purchaseId])
  @@index([checkoutTimestamp])
}

// Platform Safety #119: Chargeback Monitoring — Aggregate platform-level metrics
model PlatformMetrics {
  id               String   @id @default(cuid())
  monthYear        String   @unique // "2026-03" format
  chargebackCount  Int      @default(0)
  transactionCount Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@index([monthYear])
}

// Feature #84: Approach Notes — notification log for day-of sale alerts to shoppers
model PushNotificationLog {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type    String // "APPROACH_NOTES", "SALE_STARTS", etc.
  payload Json // Flexible payload: { saleId, title, notes, address, startDate, etc. }
  sentAt  DateTime @default(now())

  @@index([userId])
  @@index([sentAt])
}

// Feature #228: Settlement Hub — settlement record per sale
model SaleSettlement {
  id                           String        @id @default(cuid())
  saleId                       String        @unique
  sale                         Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  lifecycleStage               String        @default("LEAD") // LEAD|CONTRACTED|PREP|LIVE|POST_SALE|CLOSED
  settledAt                    DateTime?
  totalRevenue                 Decimal       @default(0)
  platformFeeAmount            Decimal       @default(0)
  totalExpenses                Decimal       @default(0)
  netProceeds                  Decimal       @default(0)
  clientPayoutRequested        DateTime?
  clientPayoutStatus           String?
  clientPayoutAmount           Decimal?
  clientPayoutMethod           String?
  clientPayoutStripeTransferId String?
  clientPayoutFailureReason    String?
  commissionRate               Decimal?
  buyerPremiumRate             Decimal?
  buyerPremiumCollected        Decimal?
  notes                        String?
  settlementNotes              String?
  internalNotes                String?
  deletedAt                    DateTime?
  createdAt                    DateTime      @default(now())
  updatedAt                    DateTime      @default(now())
  expenses                     SaleExpense[]
  clientPayout                 ClientPayout?

  @@index([saleId])
  @@index([lifecycleStage])
  @@index([clientPayoutStatus])
}

// Feature #228: Settlement Hub — expense line items
model SaleExpense {
  id           String         @id @default(cuid())
  settlementId String
  settlement   SaleSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  category     String // HAULING|ADVERTISING|STAFF|SUPPLIES|VENUE|OTHER
  description  String
  amount       Decimal
  vendorName   String?
  receiptUrl   String?
  receiptDate  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())

  @@index([settlementId])
  @@index([category])
}

// Feature #228: Settlement Hub — Stripe Connect client payout record
model ClientPayout {
  id                String         @id @default(cuid())
  settlementId      String         @unique
  settlement        SaleSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  clientName        String
  clientEmail       String?
  clientPhone       String?
  amount            Decimal
  status            String         @default("PENDING") // PENDING|PROCESSING|COMPLETED|FAILED
  method            String // STRIPE_CONNECT|MANUAL
  stripeTransferId  String?        @unique
  stripeAccountId   String?
  bankAccountLast4  String?
  bankRoutingNumber String?
  failureReason     String?
  processedAt       DateTime?
  paidAt            DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @default(now())

  @@index([settlementId])
  @@index([status])
}

// Feature #228: Sale Pulse — analytics read model for transaction tracking
model SaleTransaction {
  id            String   @id @default(cuid())
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  buyerId       String?
  buyer         User?    @relation(fields: [buyerId], references: [id], onDelete: SetNull)
  itemId        String?
  item          Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  amount        Decimal
  currency      String   @default("USD")
  paymentMethod String // STRIPE|CASH|INVOICE|OTHER
  source        String   @default("ONLINE") // ONLINE|IN_PERSON|POS
  status        String   @default("COMPLETED") // COMPLETED|REFUNDED|PENDING
  timestamp     DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([saleId, timestamp])
  @@index([buyerId])
  @@index([status])
}

// Feature #235: Charity Close + Tax Receipt PDF — donate unsold items for tax deduction
model SaleDonation {
  id                  String        @id @default(cuid())
  saleId              String
  sale                Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  organizerId         String
  organizer           Organizer     @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  charityName         String // Name of the charity receiving donation
  charityEin          String? // Tax ID / EIN for the charity
  charityAddress      String? // Charity address for receipt
  donationDate        DateTime      @default(now())
  totalEstimatedValue Decimal       @default(0) @db.Decimal(10, 2) // Sum of all donated item values
  receiptUrl          String? // URL to generated PDF receipt
  notes               String? // Optional notes about donation
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  items               DonatedItem[]

  @@index([saleId])
  @@index([organizerId])
}

// Feature #235: Line items in a donation — tracks individual items donated
model DonatedItem {
  id             String       @id @default(cuid())
  donationId     String
  donation       SaleDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  estimatedValue Decimal      @db.Decimal(10, 2) // Estimated value for this item at time of donation
  createdAt      DateTime     @default(now())

  @@index([donationId])
  @@index([itemId])
}

// POS Upgrade: Server-side session for Open Carts (shopper cart → organizer POS sync)
model POSSession {
  id          String    @id @default(cuid())
  organizerId String
  organizer   Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  saleId      String
  sale        Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  shopperId   String?
  shopper     User?     @relation("ShopperPOSSessions", fields: [shopperId], references: [id], onDelete: SetNull)
  // Cart items shared from shopper's localStorage cart
  cartItems   Json      @default("[]") // Array of {id, title, price, photoUrl, saleId}
  status      String    @default("OPEN") // OPEN | PULLED | COMPLETED | ABANDONED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime // 2 hours from creation

  @@index([organizerId, saleId, status])
  @@index([shopperId])
  @@index([expiresAt])
}

// POS Upgrade: Stripe Payment Link generated for shopper self-checkout via QR
model POSPaymentLink {
  id                   String    @id @default(cuid())
  organizerId          String
  organizer            Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  saleId               String
  sale                 Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  stripePaymentLinkId  String    @unique
  stripePaymentLinkUrl String // the buy.stripe.com/... URL
  qrCodeDataUrl        String? // base64 QR code image, generated on backend
  amount               Int // total in cents
  status               String    @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED | EXPIRED
  // Items in this payment link (for marking SOLD on webhook)
  itemIds              String[]  @default([])
  purchaseIds          String[]  @default([]) // created when shopper pays
  completedAt          DateTime?
  createdAt            DateTime  @default(now())
  expiresAt            DateTime? // 24h

  @@index([organizerId, status])
  @@index([saleId])
}

model POSPaymentRequest {
  id                    String    @id @default(cuid())
  organizerId           String
  organizerUserId       String // For socket room targeting (POS organizer)
  shopperUserId         String
  saleId                String
  itemIds               String[] // Array of item IDs
  totalAmountCents      Int
  platformFeeCents      Int // 10% of cardAmountCents (or totalAmountCents if not split)
  stripeFeeEstimate     Int?
  stripePaymentIntentId String?   @unique
  clientSecret          String?   @db.VarChar(255)
  status                String    @default("PENDING") // PENDING | ACCEPTED | PAID | DECLINED | EXPIRED | CANCELLED
  expiresAt             DateTime
  requestedAt           DateTime  @default(now())
  acceptedAt            DateTime?
  paidAt                DateTime?
  declineReason         String? // SHOPPER_CANCEL | TIMEOUT | PAYMENT_FAILED | USER_CANCEL | INSUFFICIENT_FUNDS | PAYMENT_CONCERN | OTHER
  // Split payment fields
  isSplitPayment        Boolean   @default(false)
  cashAmountCents       Int?
  cardAmountCents       Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organizer User @relation("OrganizerPaymentRequests", fields: [organizerUserId], references: [id], onDelete: Cascade)
  shopper   User @relation("ShopperPaymentRequests", fields: [shopperUserId], references: [id], onDelete: Cascade)
  sale      Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([organizerId, saleId])
  @@index([organizerUserId, saleId])
  @@index([shopperUserId, status])
  @@index([status, expiresAt])
  @@index([stripePaymentIntentId])
  @@index([isSplitPayment])
}

// Phase 2b: Explorer's Guild — Promotional Boost Purchases (dual-rail: XP or Stripe)
// Architect ADR: claude_docs/feature-notes/ADR-featured-boost-dual-rail-S418.md
model BoostPurchase {
  id                    String        @id @default(cuid())
  userId                String
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  boostType             BoostType
  targetType            String? // "SALE" | "HAUL" | "BOUNTY" | "GUIDE" | "WISHLIST" | null for global boosts
  targetId              String? // FK string (sale id, haul id, etc.) — nullable for non-targeted boosts
  paymentMethod         PaymentMethod
  xpCost                Int? // populated if paymentMethod = XP
  stripeAmountCents     Int? // populated if paymentMethod = STRIPE (e.g. 50 = $0.50)
  stripePaymentIntentId String?       @unique
  durationDays          Int // how long the boost runs
  activatedAt           DateTime      @default(now())
  expiresAt             DateTime // activatedAt + durationDays
  status                BoostStatus   @default(ACTIVE)
  refundedAt            DateTime?
  refundReason          String?
  createdAt             DateTime      @default(now())

  @@index([userId, status])
  @@index([boostType, status, expiresAt])
  @@index([targetType, targetId, status])
  @@index([expiresAt])
}

enum BoostType {
  SALE_BUMP
  HAUL_VISIBILITY
  BOUNTY_VISIBILITY
  EVENT_SPONSORSHIP
  WISHLIST_NOTIFICATION
  SEASONAL_CHALLENGE_ACCESS
  GUIDE_PUBLICATION
  RARITY_BOOST
}

enum PaymentMethod {
  XP
  STRIPE
}

enum BoostStatus {
  ACTIVE
  EXPIRED
  REFUNDED
  FAILED
  PENDING
}

// Phase 2b: Lucky Roll — weekly XP gacha outcomes
enum LuckyRollOutcome {
  CONSOLATION // 10 XP back (35%)
  XP_50 // 50 XP (28%)
  XP_100 // 100 XP break-even (15%)
  XP_200 // 200 XP (10%)
  COUPON_1 // $1-off coupon, $10+ min purchase (7%)
  XP_500 // 500 XP jackpot (4%)
  COSMETIC_RARE // Rare frame badge or username color (1%)
}

// Phase 2b: Lucky Roll — audit log of all rolls
model LuckyRoll {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  outcome    LuckyRollOutcome
  xpAwarded  Int? // null for COUPON_1 and COSMETIC_RARE outcomes
  xpSpent    Int              @default(100)
  seedHash   String // SHA256(raw seed bytes) — verifiable, not reversible
  rollNumber Int // user's annual roll sequence number (for pity-year tracking)
  pityFired  Boolean          @default(false) // true if layer-1 or layer-2 pity modified this roll
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

// Feature #13: TEAMS Team Collaboration System Models

// WorkspacePermission — fine-grained access control per role
model WorkspacePermission {
  id          String             @id @default(cuid())
  workspaceId String
  workspace   OrganizerWorkspace @relation("WorkspacePermissions", fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole
  action      String // e.g. "create_sale", "edit_sale", "manage_staff", "view_analytics"
  allowed     Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([workspaceId, role, action])
  @@index([workspaceId, role])
}

// WorkspaceRoleTemplate — predefined role templates for quick setup
model WorkspaceRoleTemplate {
  id          String   @id @default(cuid())
  name        String   @unique // "Manager", "Staff", "Viewer"
  permissions String[] // JSON-encoded or array of permission action strings
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// TeamMember — organizer team member linked to a WorkspaceMember
model TeamMember {
  id                 String                      @id @default(cuid())
  workspaceMemberId  String                      @unique
  workspaceMember    WorkspaceMember             @relation(fields: [workspaceMemberId], references: [id], onDelete: Cascade)
  role               String                      @default("MEMBER") // "MANAGER", "MEMBER", "VIEWER"
  department         String? // "Sales", "Operations", "Photography", etc.
  primaryPhone       String?
  availability       TeamMemberAvailability?
  performances       TeamMemberPerformance[]
  leaderboardEntries WorkspaceLeaderboardEntry[]
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@index([workspaceMemberId])
}

// TeamMemberAvailability — one-to-one link to TeamMember
model TeamMemberAvailability {
  id           String     @id @default(cuid())
  teamMemberId String     @unique
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  monStartTime String? // "08:00"
  monEndTime   String? // "17:00"
  tueStartTime String?
  tueEndTime   String?
  wedStartTime String?
  wedEndTime   String?
  thuStartTime String?
  thuEndTime   String?
  friStartTime String?
  friEndTime   String?
  satStartTime String?
  satEndTime   String?
  sunStartTime String?
  sunEndTime   String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([teamMemberId])
}

// TeamMemberPerformance — one-to-many link to TeamMember
model TeamMemberPerformance {
  id             String     @id @default(cuid())
  teamMemberId   String
  teamMember     TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  period         String // "WEEKLY" | "MONTHLY"
  itemsSold      Int        @default(0)
  revenue        Decimal    @default(0)
  avgItemPrice   Decimal    @default(0)
  tasksCompleted Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([teamMemberId, period])
  @@index([teamMemberId, period])
}

// WorkspaceSettings — workspace-level configuration
model WorkspaceSettings {
  id                 String             @id @default(cuid())
  workspaceId        String             @unique
  workspace          OrganizerWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String?
  description        String?
  brandRules         String?            @db.Text
  templateUsed       String?
  maxMembers         Int                @default(5)
  enableAnalytics    Boolean            @default(true)
  enableLeaderboard  Boolean            @default(true)
  enableTeamChat     Boolean            @default(true)
  commissionOverride Decimal? // Workspace-level default commission rate
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([workspaceId])
}

// WorkspaceSalesActivity — activity log for sales within a workspace
model WorkspaceSalesActivity {
  id            String             @id @default(cuid())
  workspaceId   String
  workspace     OrganizerWorkspace @relation("WorkspaceSalesActivity", fields: [workspaceId], references: [id], onDelete: Cascade)
  saleId        String
  sale          Sale               @relation("WorkspaceSalesActivity", fields: [saleId], references: [id], onDelete: Cascade)
  activityType  String // "CREATED", "PUBLISHED", "ENDED", "ITEM_ADDED", etc.
  staffMemberId String?
  description   String?
  metadata      Json? // Additional context
  createdAt     DateTime           @default(now())

  @@index([workspaceId, saleId])
  @@index([workspaceId, createdAt])
  @@index([saleId])
}

// WorkspaceSaleChat — one-to-one chat thread per workspace-sale pair
model WorkspaceSaleChat {
  id          String                 @id @default(cuid())
  workspaceId String
  workspace   OrganizerWorkspace     @relation("WorkspaceSaleChats", fields: [workspaceId], references: [id], onDelete: Cascade)
  saleId      String
  sale        Sale                   @relation("WorkspaceSaleChats", fields: [saleId], references: [id], onDelete: Cascade)
  messages    WorkspaceChatMessage[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@unique([workspaceId, saleId])
  @@index([workspaceId, saleId])
}

// WorkspaceChatMessage — individual messages in a workspace sale chat
model WorkspaceChatMessage {
  id          String            @id @default(cuid())
  chatId      String
  chat        WorkspaceSaleChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  organizerId String
  organizer   Organizer         @relation("WorkspaceChatMessages", fields: [organizerId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([chatId])
  @@index([organizerId])
  @@index([chatId, createdAt])
}

// WorkspaceTask — task assignments for team members on a sale
model WorkspaceTask {
  id          String             @id @default(cuid())
  workspaceId String
  workspace   OrganizerWorkspace @relation("WorkspaceTasks", fields: [workspaceId], references: [id], onDelete: Cascade)
  saleId      String
  sale        Sale               @relation("WorkspaceTasks", fields: [saleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  assignedTo  String? // staff member ID (flexible, not a FK)
  status      String             @default("PENDING") // "PENDING", "IN_PROGRESS", "COMPLETED"
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([workspaceId, saleId])
  @@index([workspaceId, status])
  @@index([assignedTo])
}

// WorkspaceLeaderboardEntry — individual team member performance on leaderboard
model WorkspaceLeaderboardEntry {
  id           String             @id @default(cuid())
  workspaceId  String
  workspace    OrganizerWorkspace @relation("WorkspaceLeaderboard", fields: [workspaceId], references: [id], onDelete: Cascade)
  teamMemberId String
  teamMember   TeamMember         @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  week         String // "2026-W15" ISO week format
  itemsSold    Int                @default(0)
  revenue      Decimal            @default(0)
  rank         Int? // computed rank within workspace for that week
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([workspaceId, teamMemberId, week])
  @@index([workspaceId, week])
  @@index([teamMemberId, week])
}

// WorkspaceRevenueSnapshot — daily revenue snapshot for a workspace
model WorkspaceRevenueSnapshot {
  id             String             @id @default(cuid())
  workspaceId    String
  workspace      OrganizerWorkspace @relation("WorkspaceRevenueSnapshots", fields: [workspaceId], references: [id], onDelete: Cascade)
  date           DateTime // date this snapshot is for
  totalRevenue   Decimal            @default(0)
  itemsSold      Int                @default(0)
  completedSales Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([workspaceId, date])
  @@index([workspaceId, date])
}

// WorkspaceAlert — alerts and notifications for the workspace
model WorkspaceAlert {
  id          String             @id @default(cuid())
  workspaceId String
  workspace   OrganizerWorkspace @relation("WorkspaceAlerts", fields: [workspaceId], references: [id], onDelete: Cascade)
  saleId      String?
  sale        Sale?              @relation("WorkspaceAlerts", fields: [saleId], references: [id], onDelete: SetNull)
  alertType   String // "LOW_INVENTORY", "HIGH_REVENUE", "TASK_OVERDUE", etc.
  message     String
  severity    String             @default("INFO") // "INFO", "WARNING", "CRITICAL"
  resolved    Boolean            @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([workspaceId])
  @@index([workspaceId, severity])
  @@index([saleId])
}

model EarlyAccessCache {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String
  activatedAt DateTime @default(now())
  expiresAt   DateTime
  itemsCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, expiresAt])
  @@index([category, expiresAt])
}

// FeatureFlag — kill-switch and feature rollout control (S483 Admin Feature Flags page)
model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique // e.g. "hunt_pass_enabled", "ebay_push_enabled"
  description    String   @default("")
  enabled        Boolean  @default(false)
  tierRestricted String?  // null = all tiers; "PRO", "TEAMS", etc. to restrict
  updatedAt      DateTime @updatedAt
  updatedBy      String?  // admin user id who last toggled
}

// PwaEvent — append-only event log for PWA analytics and install tracking (S483)
model PwaEvent {
  id        String   @id @default(cuid())
  eventType String   // "pwa_install_prompt", "pwa_installed", "pwa_opened", etc.
  userId    String?  // null for anonymous events
  sessionId String?  // browser session id
  metadata  String?  // JSON blob for additional context
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}

// OrganizerScore — expansion + churn signal scores, updated by daily cron (S483)
model OrganizerScore {
  id                  String    @id @default(cuid())
  organizerId         String    @unique
  organizer           Organizer @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  // Expansion signals (0–100 score, higher = more expansion-ready)
  expansionScore      Float     @default(0)
  expansionTier       String    @default("LOW")   // LOW | MEDIUM | HIGH | URGENT
  expansionTopSignal  String?   // human-readable top trigger, e.g. "fee_savings_breakeven"
  // Churn risk signals (0–100 score, higher = more at-risk)
  churnScore          Float     @default(0)
  churnBand           String    @default("GREEN") // GREEN | YELLOW | ORANGE | RED
  churnTopSignal      String?   // human-readable top trigger, e.g. "no_login_14d"
  scoredAt            DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([expansionTier])
  @@index([churnBand])
}

// ApiUsageLog — persistent daily API call + cost tracking, replaces in-memory counters (S483)
model ApiUsageLog {
  id                  String   @id @default(cuid())
  service             String   // "cloudinary", "google_vision", "anthropic", "ebay", "stripe", "resend"
  dateKey             String   // "2026-04-16" ISO date
  callCount           Int      @default(0)
  estimatedCostCents  Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([service, dateKey])
  @@index([service])
  @@index([dateKey])
}
