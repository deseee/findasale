# S192 — cache bust 2026-03-17 type-fix
FROM node:18-slim

WORKDIR /app

ENV CI=true

# OpenSSL required by Prisma client
RUN apt-get update && apt-get install -y openssl && rm -rf /var/lib/apt/lists/*

# pnpm
RUN corepack enable && corepack prepare pnpm@8.15.5 --activate

# Copy workspace manifests + lockfile
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./

# Copy required packages only
COPY packages/database ./packages/database
COPY packages/backend ./packages/backend

# Install deps (production + database for migrations)
RUN pnpm install --frozen-lockfile --filter backend... --filter database

# Generate Prisma client (use run script, not exec — exec has binary resolution issues in monorepos)
RUN pnpm --filter database run db:generate

# Build TypeScript → dist/
RUN pnpm --filter backend run build

# Set production mode only at runtime — not during build (keeps devDeps available for prisma + tsc)
ENV NODE_ENV=production

WORKDIR /app/packages/backend

# CRITICAL: This port must match PORT variable in Railway Variables.
# Railway routes public traffic to this port. If they differ, backend returns 502.
# PORT=5000 is set explicitly in Railway Variables. Update both if you change this.
EXPOSE 5000

# Start the compiled server
CMD ["node", "/app/packages/backend/dist/index.js"]
