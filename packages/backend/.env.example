PORT=5000

# Local dev: http://localhost:3000 | Production: https://finda.sale
FRONTEND_URL=https://finda.sale

# Comma-separated. Local dev: http://localhost:3000 | Production: https://finda.sale
ALLOWED_ORIGINS=https://finda.sale

JWT_SECRET=your_key_here
DATABASE_URL=your_key_here
# Direct connection for migrations (Neon)
DIRECT_URL=your_key_here
# Local dev database (optional)
LOCAL_DATABASE_URL=your_key_here

STRIPE_SECRET_KEY=your_key_here
STRIPE_PUBLISHABLE_KEY=your_key_here
# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=your_key_here

RESEND_API_KEY=your_key_here
RESEND_FROM_EMAIL=example@resend.dev

TWILIO_ACCOUNT_SID=your_key_here
TWILIO_AUTH_TOKEN=your_key_here
TWILIO_PHONE_NUMBER=+15555555555

CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ── AI Tagging — CB1 (Cloud AI path, preferred) ───────────────────────────────────────
# Google Cloud Vision API: console.cloud.google.com → APIs → Vision API → Credentials → API Key
GOOGLE_VISION_API_KEY=your_key_here
# Anthropic API: console.anthropic.com → API Keys → Create key
ANTHROPIC_API_KEY=your_key_here
# PWA Push Notifications (web-push)
# Generate keys: npx web-push generate-vapid-keys
# Add NEXT_PUBLIC_VAPID_PUBLIC_KEY to frontend .env too
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@finda.sale

# Sentry error monitoring — get DSN from sentry.io → project settings
SENTRY_DSN=

# ── Region Configuration ────────────────────────────────────────────────
# Allows the app to serve any city/region by changing env vars at deployment time.
# Defaults to Grand Rapids, MI for existing deployments.
DEFAULT_CITY=Grand Rapids
DEFAULT_STATE=Michigan
DEFAULT_STATE_ABBREV=MI
DEFAULT_LAT=42.9619
DEFAULT_LNG=-85.6789
DEFAULT_RADIUS_MILES=25
DEFAULT_COUNTY=Kent County
DEFAULT_TIMEZONE=America/Detroit
